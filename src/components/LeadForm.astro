---
interface Props {
  source?: string;
}
const { source = "website" } = Astro.props;
---

<div class="lead-form card" id="offer-form">
  <h3>Get Your Free Cash Offer</h3>
  <p class="form-subtitle">No obligation. 100% confidential.</p>
  <form id="leadForm" data-source={source}>
    <div class="form-group">
      <label for="address">Property Address</label>
      <input type="text" id="address" name="address" placeholder="123 Main St, Kansas City, MO" required />
    </div>
    <div class="form-group">
      <label for="name">Your Name</label>
      <input type="text" id="name" name="name" placeholder="John Smith" required />
    </div>
    <div class="form-group">
      <label for="phone">Phone Number</label>
      <input type="tel" id="phone" name="phone" placeholder="(816) 555-1234" required />
    </div>
    <button type="submit" class="btn btn-primary btn-lg" style="width:100%">Get My Cash Offer</button>
  </form>
  <div class="form-success" id="formSuccess" style="display:none;">
    <h3>We Got Your Info!</h3>
    <p>We'll reach out within 24 hours with your no-obligation cash offer.</p>
    <p><strong>Need to talk now?</strong> Call <a href="tel:8164292900">816-429-2900</a></p>
  </div>
  <p class="form-privacy">100% private. No spam, ever.</p>
</div>

<style>
  .lead-form {
    max-width: 440px;
  }
  .lead-form h3 {
    font-size: 1.3rem;
    margin-bottom: 4px;
  }
  .form-subtitle {
    color: var(--grey-500);
    font-size: 0.9rem;
    margin-bottom: 20px;
  }
  .form-privacy {
    text-align: center;
    font-size: 0.8rem;
    color: var(--grey-400);
    margin-top: 12px;
  }
  .form-success {
    text-align: center;
    padding: 20px 0;
  }
  .form-success h3 {
    color: var(--green);
  }
</style>

<script>
  const form = document.getElementById('leadForm');
  const success = document.getElementById('formSuccess');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]');
      if (btn) btn.textContent = 'Sending...';

      const data = new FormData(form);
      try {
        await fetch('/api/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            address: data.get('address'),
            name: data.get('name'),
            phone: data.get('phone'),
            source: form.dataset.source
          })
        });
      } catch (err) {
        // Still show success — lead data captured client-side
      }

      form.style.display = 'none';
      if (success) success.style.display = 'block';
    });
  }
</script>
