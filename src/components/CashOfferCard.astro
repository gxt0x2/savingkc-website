---
interface Props {
  medianHomeValue?: string;
  cityName?: string;
}

const { medianHomeValue = '$185,000', cityName = 'Kansas City' } = Astro.props;
const defaultValue = parseInt(medianHomeValue.replace(/[$,]/g, '')) || 185000;
---

<div class="coc" data-default-value={defaultValue}>
  <!-- TOP: Price slider -->
  <div class="coc-header">
    <label class="coc-price-label">Home Value <span class="coc-price-sub">(based on {cityName} median)</span></label>
    <div class="coc-slider-row">
      <input type="range" min="50000" max="500000" step="5000" value={defaultValue} class="coc-slider" />
      <output class="coc-price-out">{`$${defaultValue.toLocaleString()}`}</output>
    </div>
  </div>

  <!-- MAIN GRID -->
  <div class="coc-grid">
    <!-- LEFT: Cash Offer Hero -->
    <div class="coc-offer-card">
      <span class="coc-offer-tag">Saving KC Cash Offer</span>
      <div class="coc-offer-amount" data-field="cash-offer">$148,000</div>
      <span class="coc-offer-time">Close in 7-14 days</span>
    </div>

    <!-- RIGHT: Condition Selector -->
    <div class="coc-conditions">
      <button type="button" class="coc-cond coc-cond--good coc-cond--active" data-condition="0" aria-pressed="true">
        <span class="coc-cond-label">Good Shape</span>
        <span class="coc-cond-detail">~<span data-field="repair-good">$20K</span> discount</span>
      </button>
      <button type="button" class="coc-cond coc-cond--needs" data-condition="1" aria-pressed="false">
        <span class="coc-cond-label">Needs Work</span>
        <span class="coc-cond-detail">~<span data-field="repair-needs">$40K</span> discount</span>
      </button>
      <button type="button" class="coc-cond coc-cond--major" data-condition="2" aria-pressed="false">
        <span class="coc-cond-label">Major Issues</span>
        <span class="coc-cond-detail">~<span data-field="repair-major">$60K+</span> discount</span>
      </button>
    </div>
  </div>

  <!-- BREAKDOWN LIST -->
  <div class="coc-breakdown">
    <h4 class="coc-breakdown-title">What You Avoid Paying</h4>
    <div class="coc-list">
      <div class="coc-list-item">
        <span class="coc-list-dot coc-list-dot--green"></span>
        <span class="coc-list-label">Agent Commission (6%)</span>
        <span class="coc-list-value" data-field="save-commission">$0</span>
      </div>
      <div class="coc-list-item">
        <span class="coc-list-dot coc-list-dot--green"></span>
        <span class="coc-list-label">Pre-Sale Repairs</span>
        <span class="coc-list-value" data-field="save-repairs">$0</span>
      </div>
      <div class="coc-list-item">
        <span class="coc-list-dot coc-list-dot--green"></span>
        <span class="coc-list-label">Closing Costs (3%)</span>
        <span class="coc-list-value" data-field="save-closing">$0</span>
      </div>
      <div class="coc-list-item">
        <span class="coc-list-dot coc-list-dot--green"></span>
        <span class="coc-list-label">Staging & Photography</span>
        <span class="coc-list-value">$3,500</span>
      </div>
      <div class="coc-list-item">
        <span class="coc-list-dot coc-list-dot--green"></span>
        <span class="coc-list-label">Holding Costs (4 months)</span>
        <span class="coc-list-value" data-field="save-holding">$0</span>
      </div>
      <div class="coc-list-item coc-list-item--total">
        <span class="coc-list-dot"></span>
        <span class="coc-list-label">Total You Save</span>
        <span class="coc-list-value coc-list-value--total" data-field="total-saved">$0</span>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="coc-cta">
    <a href="/get-offer/" class="coc-btn">Get My Cash Offer</a>
    <a href="tel:8164292900" class="coc-phone">(816) 429-2900</a>
  </div>
</div>

<script>
  function initCOC() {
    document.querySelectorAll('.coc').forEach((calc) => {
      const hv = parseInt((calc as HTMLElement).dataset.defaultValue || '185000');
      const slider = calc.querySelector('.coc-slider') as HTMLInputElement;
      const priceOut = calc.querySelector('.coc-price-out') as HTMLElement;
      const buttons = calc.querySelectorAll('.coc-cond');

      // Condition tiers: [Good Shape, Needs Work, Major Issues]
      const tiers = [
        { discount: 0.15, repairs: 20000 },
        { discount: 0.22, repairs: 40000 },
        { discount: 0.30, repairs: 60000 },
      ];

      let currentCondition = 0;

      function fmt(n: number): string {
        return '$' + n.toLocaleString();
      }

      function fmtK(n: number): string {
        if (n >= 1000) return '$' + Math.round(n / 1000) + 'K';
        return '$' + n.toLocaleString();
      }

      function setField(field: string, value: string) {
        calc.querySelectorAll(`[data-field="${field}"]`).forEach((el) => {
          el.textContent = value;
        });
      }

      function update() {
        const val = parseInt(slider.value);
        const t = tiers[currentCondition];

        // Update price display
        priceOut.textContent = fmt(val);

        // Cash offer
        const cashOffer = Math.round(val * (1 - t.discount));
        setField('cash-offer', fmt(cashOffer));

        // Update condition card amounts for all tiers
        setField('repair-good', fmtK(Math.round(val * tiers[0].discount)));
        setField('repair-needs', fmtK(Math.round(val * tiers[1].discount)));
        setField('repair-major', fmtK(Math.round(val * tiers[2].discount)) + '+');

        // Savings breakdown
        const commission = Math.round(val * 0.06);
        const closing = Math.round(val * 0.03);
        const holding = Math.round(val * 0.02);
        const totalSaved = commission + t.repairs + closing + 3500 + holding;

        setField('save-commission', fmt(commission));
        setField('save-repairs', fmt(t.repairs));
        setField('save-closing', fmt(closing));
        setField('save-holding', fmt(holding));
        setField('total-saved', fmt(totalSaved));
      }

      // Condition buttons
      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          buttons.forEach((b) => {
            b.classList.remove('coc-cond--active');
            b.setAttribute('aria-pressed', 'false');
          });
          btn.classList.add('coc-cond--active');
          btn.setAttribute('aria-pressed', 'true');
          currentCondition = parseInt((btn as HTMLElement).dataset.condition || '0');
          update();
        });
      });

      // Slider
      slider.addEventListener('input', update);

      // Init
      update();
    });
  }

  document.addEventListener('DOMContentLoaded', initCOC);
  document.addEventListener('astro:page-load', initCOC);
</script>

<style>
  .coc {
    background: #F8FAFC;
    border: 1px solid #E2E8F0;
    border-radius: 12px;
    padding: 28px;
    margin: 40px 0;
  }

  /* Header / Slider */
  .coc-header {
    margin-bottom: 24px;
  }

  .coc-price-label {
    display: block;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--grey-800, #222);
    margin-bottom: 10px;
  }

  .coc-price-sub {
    font-weight: 400;
    color: var(--grey-500, #666);
  }

  .coc-slider-row {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .coc-slider {
    flex: 1;
    height: 6px;
    -webkit-appearance: none;
    appearance: none;
    background: #CBD5E1;
    border-radius: 3px;
    outline: none;
  }

  .coc-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #CC0000;
    cursor: pointer;
    border: 2px solid #fff;
    box-shadow: 0 1px 4px rgba(0,0,0,0.2);
  }

  .coc-slider::-moz-range-thumb {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #CC0000;
    cursor: pointer;
    border: 2px solid #fff;
    box-shadow: 0 1px 4px rgba(0,0,0,0.2);
  }

  .coc-price-out {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--grey-900, #111);
    min-width: 110px;
    text-align: right;
  }

  /* Main Grid: Offer + Conditions */
  .coc-grid {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 16px;
    margin-bottom: 24px;
  }

  /* Cash Offer Hero Card */
  .coc-offer-card {
    background: #14532D;
    border-radius: 10px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .coc-offer-tag {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #86EFAC;
    margin-bottom: 8px;
  }

  .coc-offer-amount {
    font-size: 2.5rem;
    font-weight: 900;
    color: #fff;
    line-height: 1;
    margin-bottom: 8px;
  }

  .coc-offer-time {
    font-size: 0.8rem;
    font-weight: 600;
    color: #86EFAC;
  }

  /* Condition Cards */
  .coc-conditions {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .coc-cond {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 16px;
    border-radius: 8px;
    border: 2px solid #E2E8F0;
    background: #fff;
    cursor: pointer;
    transition: all 0.15s;
    text-align: left;
  }

  .coc-cond:hover {
    border-color: #94A3B8;
  }

  .coc-cond--active.coc-cond--good {
    border-color: #16A34A;
    background: #F0FDF4;
  }

  .coc-cond--active.coc-cond--needs {
    border-color: #D97706;
    background: #FFFBEB;
  }

  .coc-cond--active.coc-cond--major {
    border-color: #DC2626;
    background: #FEF2F2;
  }

  .coc-cond-label {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--grey-800, #222);
  }

  .coc-cond-detail {
    font-size: 0.78rem;
    color: var(--grey-500, #666);
    font-weight: 500;
  }

  /* Breakdown List */
  .coc-breakdown {
    background: #fff;
    border: 1px solid #E2E8F0;
    border-radius: 10px;
    padding: 20px;
    margin-bottom: 20px;
  }

  .coc-breakdown-title {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #16A34A;
    margin-bottom: 14px;
  }

  .coc-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .coc-list-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.85rem;
    color: var(--grey-700, #444);
  }

  .coc-list-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .coc-list-dot--green {
    background: #16A34A;
  }

  .coc-list-label {
    flex: 1;
  }

  .coc-list-value {
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: #16A34A;
  }

  .coc-list-item--total {
    border-top: 2px solid #E2E8F0;
    padding-top: 10px;
    margin-top: 4px;
  }

  .coc-list-value--total {
    font-size: 1.1rem;
    font-weight: 800;
    color: #14532D;
  }

  /* CTA */
  .coc-cta {
    text-align: center;
  }

  .coc-btn {
    display: inline-block;
    background: #CC0000;
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    padding: 14px 40px;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .coc-btn:hover {
    background: #A50000;
    color: #fff;
    text-decoration: none;
  }

  .coc-phone {
    display: block;
    margin-top: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    color: #CC0000;
    text-decoration: none;
  }

  @media (max-width: 600px) {
    .coc {
      padding: 20px 16px;
    }

    .coc-grid {
      grid-template-columns: 1fr;
    }

    .coc-offer-amount {
      font-size: 2rem;
    }

    .coc-conditions {
      flex-direction: row;
    }

    .coc-cond {
      flex-direction: column;
      gap: 2px;
      padding: 10px 12px;
      flex: 1;
      text-align: center;
    }

    .coc-cond-detail {
      font-size: 0.7rem;
    }
  }
</style>
