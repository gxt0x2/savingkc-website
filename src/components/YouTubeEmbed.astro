---
interface Props {
  videoId: string;
  title: string;
}

const { videoId, title } = Astro.props;
---

<div class="yt-embed">
  <lite-youtube videoid={videoId} playlabel={`Play: ${title}`}>
    <a href={`https://youtube.com/watch?v=${videoId}`} class="lty-playbtn" title={`Play: ${title}`}>
      <span class="lyt-visually-hidden">{`Play: ${title}`}</span>
    </a>
  </lite-youtube>
  <p class="yt-caption">{title}</p>
</div>

<script>
  // lite-youtube-embed: lightweight YouTube facade
  if (!customElements.get('lite-youtube')) {
    class LiteYTEmbed extends HTMLElement {
      connectedCallback() {
        const videoId = this.getAttribute('videoid');
        if (!videoId) return;

        this.style.backgroundImage = `url(https://i.ytimg.com/vi/${videoId}/hqdefault.jpg)`;

        const playBtn = this.querySelector('.lty-playbtn');
        if (playBtn) {
          playBtn.removeAttribute('href');
          playBtn.style.cursor = 'pointer';
        }

        this.addEventListener('click', () => this.activate(), { once: true });
      }

      activate() {
        const videoId = this.getAttribute('videoid');
        const iframe = document.createElement('iframe');
        iframe.width = '100%';
        iframe.height = '100%';
        iframe.title = this.getAttribute('playlabel') || 'YouTube video';
        iframe.allow = 'accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture';
        iframe.allowFullscreen = true;
        iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1`;
        this.innerHTML = '';
        this.appendChild(iframe);
        this.classList.add('lyt-activated');
      }
    }
    customElements.define('lite-youtube', LiteYTEmbed);
  }
</script>

<style>
  .yt-embed {
    margin: 24px 0;
  }

  .yt-caption {
    font-size: 0.85rem;
    color: var(--grey-500);
    margin-top: 8px;
    text-align: center;
    font-style: italic;
  }

  lite-youtube {
    display: block;
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #000;
    background-position: center;
    background-size: cover;
    border-radius: var(--radius-lg);
    overflow: hidden;
    cursor: pointer;
    contain: content;
  }

  lite-youtube::before {
    content: attr(playlabel);
    display: block;
    position: absolute;
    top: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.6) 0%, transparent 100%);
    width: 100%;
    padding: 12px 16px;
    font-size: 0.85rem;
    color: #fff;
    z-index: 1;
    pointer-events: none;
  }

  lite-youtube .lty-playbtn {
    display: block;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 68px;
    height: 48px;
    z-index: 1;
    background-color: transparent;
    background-image: none;
    border: none;
  }

  lite-youtube .lty-playbtn::before {
    content: '';
    display: block;
    width: 68px;
    height: 48px;
    border-radius: 14%;
    background: rgba(204, 0, 0, 0.9);
    transition: background 0.15s;
  }

  lite-youtube:hover .lty-playbtn::before {
    background: #cc0000;
  }

  lite-youtube .lty-playbtn::after {
    content: '';
    display: block;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-38%, -50%);
    border-style: solid;
    border-width: 11px 0 11px 19px;
    border-color: transparent transparent transparent #fff;
  }

  lite-youtube.lyt-activated {
    cursor: auto;
  }

  lite-youtube.lyt-activated::before {
    display: none;
  }

  lite-youtube iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .lyt-visually-hidden {
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    height: 1px;
    overflow: hidden;
    position: absolute;
    white-space: nowrap;
    width: 1px;
  }
</style>
