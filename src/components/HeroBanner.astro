---
import LeadForm from '@/components/LeadForm.astro';

interface HeroStat {
  icon: string;
  number: string;
  label: string;
}

interface Props {
  heading: string;
  highlight?: string;
  greenText?: string;
  subtitle: string;
  source?: string;
  stats?: HeroStat[];
  heroSubtitle?: string;
  variant?: 'dark' | 'cream' | 'sage';
}

const defaultStats: HeroStat[] = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    number: '100+',
    label: 'Homes Purchased',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    number: '11 yrs',
    label: 'In Kansas City',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
    number: '14 days',
    label: 'Avg. Close Time',
  },
];

const { heading, highlight, greenText, subtitle, source = 'page-hero', stats, heroSubtitle, variant = 'dark' } = Astro.props;
const resolvedStats = stats || defaultStats;

// Split heading around greenText for highlighting
let headingParts: { before: string; green: string; after: string } | null = null;
if (greenText && heading.includes(greenText)) {
  const idx = heading.indexOf(greenText);
  headingParts = {
    before: heading.slice(0, idx),
    green: greenText,
    after: heading.slice(idx + greenText.length),
  };
}
---

<section class={`hero ${variant !== 'dark' ? `hero--${variant}` : ''}`}>
  <div class="container hero-inner">
    <div class="hero-content">
      <div class="hero-badge">
        <span class="stars">★★★★★</span> 4.9-Star Google Rating
      </div>
      <h1>
        {headingParts
          ? <>{headingParts.before}<span class="highlight">{headingParts.green}</span>{headingParts.after}</>
          : heading
        }
        {highlight && (
          <>{' '}<span class="highlight">{highlight}</span></>
        )}
      </h1>
      <p class="hero-sub">{subtitle}</p>
      {heroSubtitle && <p class="hero-sub-detail">{heroSubtitle}</p>}
      <div class="hero-stats">
        {resolvedStats.map((stat) => (
          <div class="stat">
            <span class="stat-icon" set:html={stat.icon} />
            <div class="stat-text">
              <strong>{stat.number}</strong>
              <span>{stat.label}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="hero-ctas">
        <a href="tel:8164292900" class="btn btn-secondary btn-lg">Call 816-429-2900</a>
        <a href="#offer-form" class="btn btn-primary btn-lg">Get My Cash Offer</a>
      </div>
    </div>
    <div class="hero-form">
      <LeadForm source={source} />
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, var(--grey-900) 0%, var(--grey-800) 100%);
    color: var(--white);
    padding: 80px 0;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 440px;
    gap: 60px;
    align-items: start;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.1);
    padding: 6px 14px;
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    margin-bottom: 20px;
  }

  .hero h1 {
    font-size: 2.8rem;
    font-weight: 900;
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .highlight {
    color: var(--green);
  }

  .hero-sub {
    font-size: 1.15rem;
    color: var(--grey-300);
    margin-bottom: 28px;
  }

  .hero-sub-detail {
    font-size: 1rem;
    color: var(--grey-400);
    margin-bottom: 24px;
    max-width: 56ch;
    line-height: 1.6;
  }

  .hero-stats {
    display: flex;
    gap: 28px;
    margin-bottom: 32px;
  }

  .stat {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .stat-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    color: var(--green);
    flex-shrink: 0;
  }

  .stat-text {
    display: flex;
    flex-direction: column;
  }

  .stat-text strong {
    font-size: 1.3rem;
    color: var(--white);
    line-height: 1.2;
  }

  .stat-text span {
    font-size: 0.8rem;
    color: var(--grey-400);
  }

  .hero-ctas {
    display: flex;
    gap: 16px;
  }

  .hero-form :global(.lead-form) {
    background: var(--white);
    color: var(--grey-800);
  }

  @media (max-width: 1000px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }

    .hero h1 {
      font-size: 2rem;
    }

    .hero-form {
      max-width: 440px;
    }
  }

  /* Cream variant */
  .hero--cream {
    background: linear-gradient(135deg, #FFFDF7 0%, #FFF3E0 100%);
    color: var(--grey-900);
  }

  .hero--cream .hero-badge {
    background: rgba(204, 0, 0, 0.08);
    color: #991B1B;
  }

  .hero--cream .hero-badge .stars {
    color: #D97706;
  }

  .hero--cream h1 {
    color: var(--grey-900);
  }

  .hero--cream .highlight {
    color: #CC0000;
  }

  .hero--cream .hero-sub {
    color: var(--grey-600);
  }

  .hero--cream .hero-sub-detail {
    color: var(--grey-500);
  }

  .hero--cream .stat-icon {
    background: rgba(204, 0, 0, 0.08);
    color: #CC0000;
  }

  .hero--cream .stat-text strong {
    color: var(--grey-900);
  }

  .hero--cream .stat-text span {
    color: var(--grey-500);
  }

  .hero--cream .hero-form :global(.lead-form) {
    border: 1px solid #E5E7EB;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  /* Sage variant — neighborhoods */
  .hero--sage {
    background: linear-gradient(135deg, #F0FDF4 0%, #ECFDF5 50%, #F0FDFA 100%);
    color: var(--grey-900);
  }

  .hero--sage .hero-badge {
    background: rgba(5, 122, 85, 0.08);
    color: #065F46;
  }

  .hero--sage .hero-badge .stars {
    color: #D97706;
  }

  .hero--sage h1 {
    color: var(--grey-900);
  }

  .hero--sage .highlight {
    color: #065F46;
  }

  .hero--sage .hero-sub {
    color: var(--grey-600);
  }

  .hero--sage .hero-sub-detail {
    color: var(--grey-500);
  }

  .hero--sage .stat-icon {
    background: rgba(5, 122, 85, 0.08);
    color: #065F46;
  }

  .hero--sage .stat-text strong {
    color: var(--grey-900);
  }

  .hero--sage .stat-text span {
    color: var(--grey-500);
  }

  .hero--sage .hero-form :global(.lead-form) {
    border: 1px solid #D1FAE5;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  @media (max-width: 640px) {
    .hero {
      padding: 40px 0;
    }

    .hero h1 {
      font-size: 1.7rem;
    }

    .hero-stats {
      gap: 20px;
    }

    .hero-ctas {
      flex-direction: column;
    }
  }
</style>
