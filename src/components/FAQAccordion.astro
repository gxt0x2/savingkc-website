---
import type { FAQItem } from '@/types/situation';

interface Props {
  items: FAQItem[];
  title?: string;
}

const { items, title } = Astro.props;
---

<div class="faq-accordion">
  {title && <h2>{title}</h2>}
  <div class="faq-list">
    {items.map((item) => (
      <details class="faq-item" open>
        <summary class="faq-question">
          <span>{item.question}</span>
          <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="faq-answer">
          <div class="faq-answer-inner">
            {item.answer}
          </div>
        </div>
      </details>
    ))}
  </div>
</div>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
})} />

<style>
  .faq-accordion {
    margin: 40px 0;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 24px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--grey-100);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .faq-item {
    border: 1px solid var(--grey-200);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--white);
    transition: all 0.2s;
  }

  .faq-item[open] {
    border-color: rgba(220, 38, 38, 0.2);
    background: rgba(250, 246, 237, 0.3);
    box-shadow: var(--shadow-md);
  }

  .faq-question {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    text-align: left;
    font-weight: 500;
    cursor: pointer;
    list-style: none;
    font-family: inherit;
    font-size: 1rem;
    transition: background 0.2s;
  }

  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::marker { display: none; content: ''; }

  .faq-question:hover {
    background: rgba(249, 250, 251, 0.5);
  }

  .faq-question span {
    color: var(--grey-900);
    padding-right: 16px;
  }

  .faq-chevron {
    flex-shrink: 0;
    color: var(--grey-400);
    transition: transform 0.2s, color 0.2s;
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
    color: var(--red);
  }

  .faq-answer {
    transition: max-height 0.3s ease;
  }

  .faq-answer-inner {
    padding: 0 20px 16px;
    color: var(--grey-700);
    line-height: 1.6;
  }

  @media (min-width: 768px) {
    .faq-question {
      padding: 20px;
    }

    .faq-answer-inner {
      padding: 0 20px 20px;
    }
  }
</style>
