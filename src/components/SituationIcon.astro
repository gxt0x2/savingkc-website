  },
  'fire-damage': {
    bg: '#ef4444',
    path: 'M12 2c.5 2-1 4-1 6 0 3 3 4 3 4s-1-1-2-1c-2 0-3 2-3 4 0 3 2.5 5 5 5s5-2 5-6c0-5-4-8-7-12z',
  },
  'water-damage': {
    bg: '#3b82f6',
    path: 'M12 2L6.5 12.5c-1.5 2.5-2 4.5-2 6 0 4.14 3.36 7.5 7.5 7.5s7.5-3.36 7.5-7.5c0-1.5-.5-3.5-2-6L12 2zM9 16c0 1.66 1.34 3 3 3',
  },
  'mold': {
    bg: '#059669',
    path: 'M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10zM8 12a2 2 0 104 0 2 2 0 00-4 0zM14 9a1.5 1.5 0 103 0 1.5 1.5 0 00-3 0zM13 15a1 1 0 102 0 1 1 0 00-2 0z',
  },
  'hoarder-house': {
    bg: '#f59e0b',
    path: 'M20 7l-8-4-8 4m16 0v10l-8 4m8-14l-8 4m-8-4v10l8 4m-8-14l8 4m0 0v10',
  },
  'inherited-property': {
    bg: '#a855f7',
    path: 'M9 12h6m-3-3v6m-7 4h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2zM12 2v3M8 2l1 3M16 2l-1 3',
  },
  'divorce': {
    bg: '#6366f1',
    path: 'M3 6l3 6h12l3-6M9 18a3 3 0 106 0M6 12v4a2 2 0 002 2M18 12v4a2 2 0 01-2 2M12 12v6M4 6h16',
  },
  'behind-on-payments': {
    bg: '#eab308',
    path: 'M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6',
  },
  'pre-foreclosure': {
    bg: '#e11d48',
    path: 'M12 9v2m0 4h.01M5.07 19H19a2 2 0 001.75-2.97L13.75 4a2 2 0 00-3.5 0L3.32 16.03A2 2 0 005.07 19z',
  },
  'vacant-property': {
    bg: '#64748b',
    path: 'M3 21h18M5 21V7l7-4 7 4v14M9 21v-4h6v4M9 10h1M14 10h1M9 14h1M14 14h1',
  },
  'bad-tenants': {
    bg: '#14b8a6',
    path: 'M15 7h3a2 2 0 012 2v9a2 2 0 01-2 2h-3M10 17l5-5-5-5M15 12H3',
  },
  'code-violations': {
    bg: '#dc2626',
    path: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2M12 11v4M12 11V9',
  },
};

const defaultConfig = {
  bg: '#dc2626',
  path: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
};

const config = iconConfigs[slug] || defaultConfig;
---

<div
  class="situation-icon"
  style={`width: ${size}px; height: ${size}px; background: ${config.bg};`}
>
  <svg
    width={iconSize}
    height={iconSize}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d={config.path} />
  </svg>
</div>

<style>
  .situation-icon {
    border-radius: var(--radius-xl);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--white);
  }
</style>
