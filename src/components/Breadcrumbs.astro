---
import type { BreadcrumbItem } from '@/types/content';

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="breadcrumbs">
  <ol>
    <li>
      <a href="/">Home</a>
    </li>
    {items.map((item) => (
      <li>
        <span class="separator">/</span>
        {item.href ? (
          <a href={item.href}>{item.label}</a>
        ) : (
          <span class="current">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumbs {
    font-size: 0.875rem;
    color: var(--grey-500);
    padding: 12px 0;
  }

  ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4px;
    list-style: none;
  }

  li {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  a {
    color: var(--grey-500);
    text-decoration: none;
    transition: color 0.2s;
  }

  a:hover {
    color: var(--red);
  }

  .separator {
    margin: 0 4px;
    color: var(--grey-300);
  }

  .current {
    color: var(--grey-900);
    font-weight: 500;
  }
</style>
