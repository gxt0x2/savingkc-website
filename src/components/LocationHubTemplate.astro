---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroBanner from '@/components/HeroBanner.astro';
import PageShell from '@/components/PageShell.astro';
import ShortAnswerBlock from '@/components/ShortAnswerBlock.astro';
import ComparisonTable from '@/components/ComparisonTable.astro';
import StepTimeline from '@/components/StepTimeline.astro';
import CalibratedQuestionCTA from '@/components/CalibratedQuestionCTA.astro';
import FAQ from '@/components/FAQ.astro';
import LeadForm from '@/components/LeadForm.astro';
import QuickFactsSidebar from '@/components/QuickFactsSidebar.astro';
import ContactSidebar from '@/components/ContactSidebar.astro';
import KeyTermsSidebar from '@/components/KeyTermsSidebar.astro';
import type { BreadcrumbItem } from '@/types/content';

interface ChildEntity {
  name: string;
  href: string;
  subtitle?: string;
  badge?: string;
  description?: string;
}

interface Props {
  title: string;
  description: string;
  shortAnswer: string;
  breadcrumbs: BreadcrumbItem[];
  children: ChildEntity[];
  facts?: { label: string; value: string }[];
  locationName?: string;
  countyName?: string;
  stateName?: string;
  medianValue?: string;
  contactItems?: { label: string; value: string; href?: string }[];
  countyPills?: { label: string; href: string }[];
  relatedLinks?: { label: string; href: string }[];
  canonical?: string;
  metaTitle?: string;
  metaDescription?: string;
}

const {
  title,
  description,
  shortAnswer,
  breadcrumbs,
  children: childEntities,
  facts,
  locationName,
  contactItems,
  countyPills,
  relatedLinks,
  canonical,
  metaTitle,
  metaDescription,
} = Astro.props;

const name = locationName || title.replace(/Sell Your House for Cash in /g, '').replace(/, (MO|KS)$/g, '');

const defaultComparison = [
  { label: 'Repairs Before Selling', left: '$0. Sell as-is', right: '$5,000-$30,000+ out of pocket' },
  { label: 'Agent Commissions', left: '0%. No agents', right: '5-6% of sale price' },
  { label: 'Closing Costs', left: 'We pay all closing costs', right: 'Seller pays 1-3%' },
  { label: 'Time to Sell', left: '7-14 days', right: '3-6 months on MLS' },
  { label: 'Showings', left: 'One walkthrough', right: 'Weeks of open houses' },
  { label: 'Financing Risk', left: 'Cash. No contingencies', right: '15-20% of deals fall through' },
];

const defaultSteps = [
  { title: 'Contact Us', description: 'Call or fill out our online form. Tell us about your property, its condition, and your timeline. No obligation.' },
  { title: 'Get Your Cash Offer', description: 'We visit the property, assess its condition, and present a fair written cash offer, usually within 24 hours.' },
  { title: 'Choose Your Closing Date', description: 'Accept the offer and pick your closing date. As soon as 7 days or up to 60 days. Whatever works for you.' },
  { title: 'Get Paid', description: "Sign at a local title company and receive your funds via wire transfer or cashier's check the same day." },
];

const faqs = [
  {
    question: `How fast can you close on a house in ${name}?`,
    answer: `We can close in as few as 7 days. Because we pay cash, there's no lender approval, no appraisal, and no financing delays. You choose the date that works best for you, up to 60 days out if you need more time.`,
  },
  {
    question: `Do I need to make repairs before selling?`,
    answer: `No. We buy homes in any condition. Foundation problems, roof damage, mold, fire damage, water damage, outdated everything. We've seen it all and we buy it all. You don't spend a dime on repairs.`,
  },
  {
    question: `How much will you offer for my house?`,
    answer: `Our offers are based on the after-repair value of the home minus estimated repair costs and our margin. We show you exactly how we get to our number. While the offer will be below full retail value, you save on commissions (5-6%), repairs ($5,000-$30,000+), closing costs (1-3%), and months of holding costs.`,
  },
  {
    question: `Are there any fees or commissions?`,
    answer: `None. We don't charge commissions, fees, or closing costs. The offer amount is what you receive at closing. We pay all title company fees and closing costs ourselves.`,
  },
  {
    question: `What if my house has liens or back taxes?`,
    answer: `We buy properties with liens, back taxes, and title issues. The title company resolves these at closing using the sale proceeds. You don't need to clear them beforehand.`,
  },
  {
    question: `Can I sell if I'm behind on mortgage payments?`,
    answer: `Yes. Many homeowners who sell to us are behind on payments or facing foreclosure. We can often close fast enough to stop foreclosure proceedings and help you avoid a hit to your credit.`,
  },
];
---

<BaseLayout title={metaTitle || title} description={metaDescription || description} canonical={canonical}>
  <HeroBanner
    heading={title}
    highlight="For Cash"
    subtitle={description}
    source={`${name.toLowerCase().replace(/\s+/g, '-')}-hero`}
  />

  <PageShell breadcrumbs={breadcrumbs}>
    <ShortAnswerBlock answer={shortAnswer} />

    <!-- Child Entity Cards -->
    <section class="child-cards-section">
      <div class="child-cards-grid">
        {childEntities.map((child) => (
          <a href={child.href} class="child-card card">
            <div class="child-card-header">
              <h3>{child.name}</h3>
              <div class="child-card-meta">
                {child.badge && <span class="badge">{child.badge}</span>}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 5l7 7-7 7" /></svg>
              </div>
            </div>
            {child.subtitle && <p class="child-subtitle">{child.subtitle}</p>}
            {child.description && <p class="child-desc">{child.description}</p>}
          </a>
        ))}
      </div>
    </section>

    <!-- Why Cash Sale Section -->
    <section class="content-section">
      <h2>Why Do {name} Homeowners Sell for Cash?</h2>
      <div class="section-body">
        <p>
          Homeowners in {name} sell to us for a lot of reasons. Some own a house that
          needs more work than they can afford. Others inherited a property they don't
          want. Some are going through a divorce and need to split assets quickly.
          Others are behind on payments and running out of time.
        </p>
        <p>
          Whatever the situation, the traditional selling process doesn't work for
          everyone. Listing with an agent means paying 5-6% in commissions, spending
          thousands on repairs to pass inspection, hosting weeks of showings, and waiting
          3 to 6 months to close. If your house has problems or you need to sell fast,
          the traditional path costs you more time and money than it's worth.
        </p>
        <p>
          A cash sale cuts through all of that. We make an offer based on the property's
          current condition, we pay all closing costs, and we close on your timeline.
          No agents, no repairs, no uncertainty.
        </p>
      </div>
    </section>

    <ComparisonTable rows={defaultComparison} />

    <StepTimeline steps={defaultSteps} />

    <slot />

    <FAQ items={faqs} />

    <CalibratedQuestionCTA />

    <Fragment slot="sidebar">
      <LeadForm />
      {contactItems && contactItems.length > 0 && <ContactSidebar items={contactItems} />}
      {countyPills && countyPills.length > 0 && (
        <div class="sidebar-box">
          <h3>Nearby Cities</h3>
          <div class="county-pills">
            {countyPills.map((pill) => (
              <a href={pill.href} class="county-pill">{pill.label}</a>
            ))}
          </div>
        </div>
      )}
      {facts && <QuickFactsSidebar facts={facts} />}
      <KeyTermsSidebar terms={[
        { term: 'Cash Offer', definition: 'A purchase offer made without mortgage financing. No appraisal, no lender delays, no risk of deal falling through.' },
        { term: 'As-Is Sale', definition: 'Selling your home in its current condition with no repairs, cleaning, or improvements required before closing.' },
        { term: 'Closing Costs', definition: 'Fees charged at closing for title search, title insurance, recording, and transfer taxes. We pay all of these.' },
        { term: 'Fair Market Value', definition: 'What a home would sell for on the open market in good condition. Our offers factor in repair costs and selling expenses you avoid.' },
        { term: 'Title Search', definition: 'A review of public records to confirm ownership and identify any liens, judgments, or encumbrances on the property.' },
      ]} />
      {relatedLinks && relatedLinks.length > 0 && (
        <div class="sidebar-box">
          <h3>Related Resources</h3>
          <ul class="sidebar-links">
            {relatedLinks.map((link) => (
              <li>
                <a href={link.href}>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 5l7 7-7 7" /></svg>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </Fragment>
  </PageShell>
</BaseLayout>

<style>
  .page-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 12px;
    line-height: 1.1;
  }

  .page-desc {
    font-size: 1.125rem;
    color: var(--grey-500);
    margin-bottom: 32px;
    line-height: 1.6;
  }

  .child-cards-section {
    margin: 40px 0;
  }

  .child-cards-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .child-card {
    display: block;
    padding: 20px;
    border: 1px solid var(--grey-200);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }

  .child-card:hover {
    border-color: var(--red);
    box-shadow: var(--shadow-lg);
    text-decoration: none;
  }

  .child-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .child-card h3 {
    font-weight: 700;
    font-size: 1.125rem;
    transition: color 0.2s;
  }

  .child-card:hover h3 {
    color: var(--red);
  }

  .child-card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .child-card-meta svg {
    color: var(--grey-300);
    transition: all 0.2s;
  }

  .child-card:hover .child-card-meta svg {
    color: var(--red);
    transform: translateX(2px);
  }

  .child-subtitle {
    font-size: 0.875rem;
    color: var(--grey-500);
    margin-top: 4px;
  }

  .child-desc {
    font-size: 0.875rem;
    color: var(--grey-500);
    margin-top: 8px;
    line-height: 1.6;
  }

  .content-section {
    margin: 40px 0;
    scroll-margin-top: 96px;
  }

  .content-section h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--grey-100);
  }

  .section-body {
    color: var(--grey-700);
    line-height: 1.6;
  }

  .section-body p {
    margin-bottom: 16px;
  }

  .section-body p:last-child {
    margin-bottom: 0;
  }

  .sidebar-box {
    background: var(--grey-50);
    border-radius: var(--radius-lg);
    padding: 24px;
  }

  .sidebar-box h3 {
    font-weight: 700;
    font-size: 1.125rem;
    margin-bottom: 16px;
  }

  .sidebar-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sidebar-links a {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    color: var(--grey-700);
    text-decoration: none;
    transition: color 0.2s;
  }

  .sidebar-links a:hover {
    color: var(--red);
  }

  .sidebar-links svg {
    color: var(--red);
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .child-cards-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 768px) {
    .page-title {
      font-size: 2.5rem;
    }
  }
</style>
