  <style>
    /* ========== Navigation ========== */
    .nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--white);
      border-bottom: 1px solid var(--grey-200);
    }
    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: var(--nav-height);
    }
    .nav-logo {
      font-weight: 800;
      font-size: 1.2rem;
      color: var(--grey-900);
      flex-shrink: 0;
    }
    .nav-logo:hover { text-decoration: none; }

    /* Desktop nav links */
    .nav-links-desktop {
      display: flex;
      align-items: center;
      gap: 28px;
    }
    .nav-links-desktop > a {
      color: var(--grey-600);
      font-weight: 500;
      font-size: 0.95rem;
    }
    .nav-links-desktop > a:hover {
      color: var(--grey-900);
      text-decoration: none;
    }
    .nav-cta-desktop {
      display: flex;
      gap: 12px;
      align-items: center;
    }
    .nav-phone {
      font-weight: 700;
    }

    /* Hamburger */
    .nav-toggle {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
    }
    .nav-toggle span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--grey-700);
      transition: 0.2s;
    }

    /* Mobile panel — hidden on desktop */
    .mobile-panel {
      display: none;
    }

    /* ========== Desktop Mega Menu ========== */
    .mega-trigger {
      position: relative;
    }
    .mega-btn {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      background: none;
      border: none;
      cursor: pointer;
      color: var(--grey-600);
      font-weight: 500;
      font-size: 0.95rem;
      font-family: var(--font-sans);
      padding: 0;
    }
    .mega-btn:hover { color: var(--grey-900); }
    .mega-btn.active { color: var(--red); }
    .mega-chevron { transition: transform 0.2s; }
    .mega-btn.active .mega-chevron { transform: rotate(180deg); }

    .mega-dropdown {
      display: none;
      position: fixed;
      top: var(--nav-height);
      left: 50%;
      transform: translateX(-50%);
      width: min(700px, calc(100vw - 40px));
      z-index: 200;
      padding-top: 8px;
    }
    .mega-dropdown.open {
      display: block;
      animation: fadeIn 0.15s ease;
    }
    .mega-inner {
      background: var(--white);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-xl);
      border: 1px solid var(--grey-200);
      padding: 28px 32px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
    .mega-state {
      display: block;
      font-size: 1.1rem;
      font-weight: 800;
      color: var(--grey-900);
      margin-bottom: 16px;
      padding-bottom: 8px;
      border-bottom: 2px solid var(--red);
    }
    .mega-state:hover { color: var(--red); text-decoration: none; }
    .mega-county { margin-bottom: 16px; }
    .mega-county-title {
      display: block;
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--red);
      margin-bottom: 6px;
    }
    .mega-county-title:hover { color: var(--red-dark); text-decoration: none; }
    .mega-county a:not(.mega-county-title) {
      display: block;
      font-size: 0.9rem;
      color: var(--grey-600);
      padding: 3px 0;
    }
    .mega-county a:not(.mega-county-title):hover {
      color: var(--grey-900);
      text-decoration: none;
    }

    /* ========== Mobile (≤900px) ========== */
    @media (max-width: 900px) {
      .nav-links-desktop,
      .nav-cta-desktop { display: none; }
      .nav-toggle { display: flex; }

      .mobile-panel {
        display: none;
        border-top: 1px solid var(--grey-200);
        background: var(--white);
        max-height: calc(100vh - var(--nav-height));
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
      }
      .mobile-panel.open {
        display: block;
      }

      .mobile-nav {
        padding: 12px 20px 20px;
      }

      /* Nav links */
      .mobile-nav-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        padding: 12px 0;
        font-size: 1rem;
        font-weight: 500;
        color: var(--grey-700);
        border-bottom: 1px solid var(--grey-100);
      }
      .mobile-nav-link:hover {
        color: var(--red);
        text-decoration: none;
      }
      a.mobile-nav-link { cursor: pointer; }
      button.mobile-nav-link {
        background: none;
        border: none;
        border-bottom: 1px solid var(--grey-100);
        cursor: pointer;
        font-family: var(--font-sans);
        text-align: left;
      }

      /* Chevron rotation */
      .mobile-chev { transition: transform 0.2s; }
      .mobile-accordion-trigger.open .mobile-chev,
      .mobile-state-btn.open .mobile-chev {
        transform: rotate(180deg);
      }

      /* Service areas accordion body */
      .mobile-accordion-body {
        display: none;
        padding: 4px 0 8px 8px;
      }
      .mobile-accordion-body.open { display: block; }

      /* State buttons */
      .mobile-state-btn {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        padding: 10px 0;
        font-size: 0.95rem;
        font-weight: 600;
        font-family: var(--font-sans);
        color: var(--grey-800);
        background: none;
        border: none;
        cursor: pointer;
        text-align: left;
      }
      .mobile-state-btn:hover { color: var(--red); }

      /* State body */
      .mobile-state-body {
        display: none;
        padding: 0 0 8px 12px;
      }
      .mobile-state-body.open { display: block; }
      .mobile-state-body a {
        display: block;
        font-size: 0.9rem;
        color: var(--grey-700);
        padding: 5px 0;
      }
      .mobile-state-body a:hover {
        color: var(--red);
        text-decoration: none;
      }
      .mobile-all-link {
        font-weight: 600;
        color: var(--red) !important;
        font-size: 0.85rem !important;
      }
      .mobile-county-label {
        display: block;
        margin-top: 10px;
      }
      .mobile-county-label a {
        font-size: 0.75rem !important;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--grey-400) !important;
        padding: 2px 0 !important;
      }
      .mobile-county-label a:hover {
        color: var(--red) !important;
      }

      /* CTA buttons */
      .mobile-cta {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid var(--grey-200);
      }
    }

    /* ========== Footer ========== */
    .footer {
      background: var(--grey-900);
      color: var(--grey-300);
      padding: 60px 0 30px;
    }
    .footer-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 32px;
      margin-bottom: 40px;
    }
    .footer-col h4 {
      color: var(--white);
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 16px;
    }
    .footer-col a {
      display: block;
      color: var(--grey-400);
      font-size: 0.9rem;
      margin-bottom: 8px;
    }
    .footer-col a:hover {
      color: var(--white);
    }
    .footer-col p {
      font-size: 0.9rem;
      margin-bottom: 8px;
    }
    .footer-social {
      display: flex;
      gap: 16px;
      margin-top: 12px;
    }
    .footer-bottom {
      border-top: 1px solid var(--grey-700);
      padding-top: 20px;
      text-align: center;
      font-size: 0.85rem;
      color: var(--grey-500);
    }

    @media (max-width: 900px) {
      .footer-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (max-width: 640px) {
      .footer-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    // Mobile nav toggle
    const toggle = document.getElementById('navToggle');
    const mobilePanel = document.getElementById('mobilePanel');

    if (toggle && mobilePanel) {
      toggle.addEventListener('click', () => {
        mobilePanel.classList.toggle('open');
      });
    }

    // Desktop mega menu — hover with delay
    const megaTrigger = document.getElementById('megaTrigger');
    const megaBtn = document.getElementById('megaBtn');
    const megaDropdown = document.getElementById('megaDropdown');
    let megaTimer = null;

    function openMega() {
      if (megaTimer) clearTimeout(megaTimer);
      megaTimer = setTimeout(() => {
        megaDropdown?.classList.add('open');
        megaBtn?.classList.add('active');
      }, 150);
    }

    function closeMega() {
      if (megaTimer) clearTimeout(megaTimer);
      megaTimer = setTimeout(() => {
        megaDropdown?.classList.remove('open');
        megaBtn?.classList.remove('active');
      }, 150);
    }

    if (megaTrigger) {
      megaTrigger.addEventListener('mouseenter', openMega);
      megaTrigger.addEventListener('mouseleave', closeMega);
    }

    if (megaBtn) {
      megaBtn.addEventListener('click', () => {
        const isOpen = megaDropdown?.classList.toggle('open');
        megaBtn.classList.toggle('active', !!isOpen);
      });
    }

    // Close mega on click outside
    document.addEventListener('mousedown', (e) => {
      if (megaTrigger && !megaTrigger.contains(e.target)) {
        megaDropdown?.classList.remove('open');
        megaBtn?.classList.remove('active');
      }
    });

    // Mobile: Service Areas accordion
    const mobileAreasTrigger = document.getElementById('mobileAreasTrigger');
    const mobileAreasBody = document.getElementById('mobileAreasBody');

    if (mobileAreasTrigger && mobileAreasBody) {
      mobileAreasTrigger.addEventListener('click', () => {
        mobileAreasTrigger.classList.toggle('open');
        mobileAreasBody.classList.toggle('open');
      });
    }

    // Mobile: State toggles
    document.querySelectorAll('.mobile-state-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const state = btn.dataset.state;
        const body = document.querySelector(`[data-state-body="${state}"]`);
        btn.classList.toggle('open');
        body?.classList.toggle('open');
      });
    });
  </script>
</body>
</html>
