---
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const { title, description = "Saving KC Homebuyers — We buy houses in Kansas City for cash. No repairs, no agent fees, close in as few as 14 days.", canonical } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {canonical && <link rel="canonical" href={canonical} />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  {canonical && <meta property="og:url" content={canonical} />}
  <meta property="og:site_name" content="Saving KC Homebuyers" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Schema: RealEstateAgent -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "RealEstateAgent",
    "name": "Saving KC Homebuyers",
    "url": "https://savingkchomebuyers.com",
    "telephone": "+1-816-429-2900",
    "email": "info@savingkchomebuyers.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Kansas City",
      "addressRegion": "MO"
    },
    "areaServed": ["Jackson County", "Clay County", "Platte County", "Wyandotte County", "Johnson County"],
    "openingHours": "Mo-Su 08:00-20:00"
  })} />
</head>
<body>
  <header class="nav">
    <div class="container nav-inner">
      <a href="/" class="nav-logo">Saving KC Homebuyers</a>

      <!-- Desktop nav -->
      <nav class="nav-links-desktop">
        <div class="mega-trigger" id="megaTrigger">
          <button type="button" class="mega-btn" id="megaBtn" aria-expanded="false" aria-haspopup="true">
            Service Areas
            <svg class="mega-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="mega-dropdown" id="megaDropdown">
            <div class="mega-inner">
              <div class="mega-col">
                <a href="/mo/" class="mega-state">Missouri</a>
                <div class="mega-county">
                  <a href="/mo/jackson/" class="mega-county-title">Jackson County</a>
                  <a href="/mo/jackson/kansas-city/">Kansas City</a>
                  <a href="/mo/jackson/independence/">Independence</a>
                  <a href="/mo/jackson/blue-springs/">Blue Springs</a>
                  <a href="/mo/jackson/lees-summit/">Lee's Summit</a>
                  <a href="/mo/jackson/grandview/">Grandview</a>
                  <a href="/mo/jackson/raytown/">Raytown</a>
                </div>
                <div class="mega-county">
                  <a href="/mo/clay/" class="mega-county-title">Clay County</a>
                  <a href="/mo/clay/liberty/">Liberty</a>
                  <a href="/mo/clay/gladstone/">Gladstone</a>
                  <a href="/mo/clay/kearney/">Kearney</a>
                  <a href="/mo/clay/excelsior-springs/">Excelsior Springs</a>
                  <a href="/mo/clay/north-kansas-city/">North KC</a>
                </div>
                <div class="mega-county">
                  <a href="/mo/platte/" class="mega-county-title">Platte County</a>
                  <a href="/mo/platte/platte-city/">Platte City</a>
                  <a href="/mo/platte/parkville/">Parkville</a>
                  <a href="/mo/platte/weatherby-lake/">Weatherby Lake</a>
                  <a href="/mo/platte/riverside/">Riverside</a>
                </div>
              </div>
              <div class="mega-col">
                <a href="/ks/" class="mega-state">Kansas</a>
                <div class="mega-county">
                  <a href="/ks/wyandotte/" class="mega-county-title">Wyandotte County</a>
                  <a href="/ks/wyandotte/kansas-city/">Kansas City KS</a>
                  <a href="/ks/wyandotte/bonner-springs/">Bonner Springs</a>
                  <a href="/ks/wyandotte/edwardsville/">Edwardsville</a>
                </div>
                <div class="mega-county">
                  <a href="/ks/johnson/" class="mega-county-title">Johnson County</a>
                  <a href="/ks/johnson/overland-park/">Overland Park</a>
                  <a href="/ks/johnson/olathe/">Olathe</a>
                  <a href="/ks/johnson/shawnee/">Shawnee</a>
                  <a href="/ks/johnson/lenexa/">Lenexa</a>
                  <a href="/ks/johnson/merriam/">Merriam</a>
                  <a href="/ks/johnson/mission/">Mission</a>
                </div>
              </div>
            </div>
          </div>
        </div>
        <a href="/#how-it-works">How It Works</a>
        <a href="/#about">About Ernest</a>
        <a href="/#reviews">Reviews</a>
        <a href="/#faq">FAQ</a>
      </nav>

      <div class="nav-cta-desktop">
        <a href="tel:8164292900" class="btn btn-secondary nav-phone">816-429-2900</a>
        <a href="/#offer-form" class="btn btn-primary">Get My Cash Offer</a>
      </div>

      <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
    </div>

    <!-- Mobile slide-down panel -->
    <div class="mobile-panel" id="mobilePanel">
      <nav class="mobile-nav">
        <!-- Service Areas accordion -->
        <div class="mobile-accordion">
          <button type="button" class="mobile-nav-link mobile-accordion-trigger" id="mobileAreasTrigger">
            Service Areas
            <svg class="mobile-chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="mobile-accordion-body" id="mobileAreasBody">
            <!-- Missouri -->
            <div class="mobile-state">
              <button type="button" class="mobile-state-btn" data-state="mo">
                Missouri
                <svg class="mobile-chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
              </button>
              <div class="mobile-state-body" data-state-body="mo">
                <a href="/mo/" class="mobile-all-link">All Missouri →</a>
                <span class="mobile-county-label"><a href="/mo/jackson/">Jackson County</a></span>
                <a href="/mo/jackson/kansas-city/">Kansas City</a>
                <a href="/mo/jackson/independence/">Independence</a>
                <a href="/mo/jackson/blue-springs/">Blue Springs</a>
                <a href="/mo/jackson/lees-summit/">Lee's Summit</a>
                <a href="/mo/jackson/grandview/">Grandview</a>
                <a href="/mo/jackson/raytown/">Raytown</a>
                <span class="mobile-county-label"><a href="/mo/clay/">Clay County</a></span>
                <a href="/mo/clay/liberty/">Liberty</a>
                <a href="/mo/clay/gladstone/">Gladstone</a>
                <a href="/mo/clay/kearney/">Kearney</a>
                <a href="/mo/clay/excelsior-springs/">Excelsior Springs</a>
                <a href="/mo/clay/north-kansas-city/">North KC</a>
                <span class="mobile-county-label"><a href="/mo/platte/">Platte County</a></span>
                <a href="/mo/platte/platte-city/">Platte City</a>
                <a href="/mo/platte/parkville/">Parkville</a>
                <a href="/mo/platte/weatherby-lake/">Weatherby Lake</a>
                <a href="/mo/platte/riverside/">Riverside</a>
              </div>
            </div>
            <!-- Kansas -->
            <div class="mobile-state">
              <button type="button" class="mobile-state-btn" data-state="ks">
                Kansas
                <svg class="mobile-chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
              </button>
              <div class="mobile-state-body" data-state-body="ks">
                <a href="/ks/" class="mobile-all-link">All Kansas →</a>
                <span class="mobile-county-label"><a href="/ks/wyandotte/">Wyandotte County</a></span>
                <a href="/ks/wyandotte/kansas-city/">Kansas City KS</a>
                <a href="/ks/wyandotte/bonner-springs/">Bonner Springs</a>
                <a href="/ks/wyandotte/edwardsville/">Edwardsville</a>
                <span class="mobile-county-label"><a href="/ks/johnson/">Johnson County</a></span>
                <a href="/ks/johnson/overland-park/">Overland Park</a>
                <a href="/ks/johnson/olathe/">Olathe</a>
                <a href="/ks/johnson/shawnee/">Shawnee</a>
                <a href="/ks/johnson/lenexa/">Lenexa</a>
                <a href="/ks/johnson/merriam/">Merriam</a>
                <a href="/ks/johnson/mission/">Mission</a>
              </div>
            </div>
          </div>
        </div>

        <a href="/#how-it-works" class="mobile-nav-link">How It Works</a>
        <a href="/#about" class="mobile-nav-link">About Ernest</a>
        <a href="/#reviews" class="mobile-nav-link">Reviews</a>
        <a href="/#faq" class="mobile-nav-link">FAQ</a>

        <div class="mobile-cta">
          <a href="tel:8164292900" class="btn btn-secondary" style="width:100%">816-429-2900</a>
          <a href="/#offer-form" class="btn btn-primary" style="width:100%">Get My Cash Offer</a>
        </div>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4>Company</h4>
          <a href="/how-it-works/">How It Works</a>
          <a href="/about-us/">About</a>
          <a href="/reviews/">Reviews</a>
          <a href="/faq/">FAQ</a>
          <a href="/contact/">Contact</a>
        </div>
        <div class="footer-col">
          <h4>Situations</h4>
          <a href="/situations/pre-foreclosure/">Pre-Foreclosure</a>
          <a href="/situations/inherited-property/">Inherited Property</a>
          <a href="/situations/divorce/">Divorce</a>
          <a href="/tax-delinquent/">Tax Delinquent</a>
          <a href="/situations/vacant-property/">Vacant Property</a>
        </div>
        <div class="footer-col">
          <h4>Resources</h4>
          <a href="/probate/">Probate Guide</a>
          <a href="/tax-delinquent/">Tax Delinquent Guide</a>
          <a href="/tax-delinquent/redemption/jackson-county/">Jackson County Redemption</a>
          <a href="/tax-delinquent/payment-plans/jackson-county/">Jackson County Payment Plans</a>
          <a href="/tax-delinquent/payment-plans/johnson-county/">Johnson County Payment Plans</a>
        </div>
        <div class="footer-col">
          <h4>Service Areas</h4>
          <a href="/mo/jackson/kansas-city/">Kansas City MO</a>
          <a href="/mo/jackson/independence/">Independence</a>
          <a href="/mo/jackson/blue-springs/">Blue Springs</a>
          <a href="/ks/johnson/overland-park/">Overland Park</a>
          <a href="/ks/wyandotte/kansas-city/">Kansas City KS</a>
        </div>
        <div class="footer-col">
          <h4>Contact</h4>
          <p><a href="tel:8164292900">816-429-2900</a></p>
          <p><a href="mailto:info@savingkchomebuyers.com">info@savingkchomebuyers.com</a></p>
          <div class="footer-social">
            <a href="https://facebook.com" target="_blank" rel="noopener">Facebook</a>
            <a href="https://youtube.com" target="_blank" rel="noopener">YouTube</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Saving KC Homebuyers. All rights reserved. <a href="/privacy/">Privacy Policy</a> · <a href="/terms/">Terms of Service</a></p>
      </div>
    </div>
