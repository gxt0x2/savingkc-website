---
import LocationHubTemplate from '@/components/LocationHubTemplate.astro';
import CalloutBox from '@/components/CalloutBox.astro';
import { getCountiesByState } from '@/data/counties';
import { neighborhoodUrl, cityUrl } from '@/lib/urls';
import { brand } from '@/data/brand';

export function getStaticPaths() {
  return getCountiesByState('ks').flatMap((county) =>
    county.cities.map((city) => ({
      params: { county: county.slug, city: city.slug },
      props: { city, county },
    }))
  );
}

const { city, county } = Astro.props;
const stateAbbr = 'KS';
const stateName = 'Kansas';
const stateSlug = 'ks';

// Build children (neighborhoods) for the template
const children = city.neighborhoods.map((n) => ({
  name: n.name,
  href: neighborhoodUrl(stateSlug, county.slug, city.slug, n.slug),
  subtitle: `Median: ${n.medianHomeValue}`,
  description: n.description,
}));

// Quick facts for sidebar with colored values
const medianNum = parseInt(city.medianHomeValue.replace(/[$,]/g, ''));
const commissionEstimate = medianNum > 0 ? `$${Math.round(medianNum * 0.055).toLocaleString()}` : 'thousands';

const facts = [
  { label: 'City', value: city.name },
  { label: 'County', value: `${county.name}` },
  { label: 'ZIP Codes', value: city.zipCodes?.join(', ') || 'N/A' },
  { label: 'Population', value: city.population },
  { label: 'Median Home Value', value: city.medianHomeValue, color: 'red' as const },
  { label: 'Neighborhoods', value: `${city.neighborhoods.length}` },
  { label: 'Agent Commissions', value: commissionEstimate, color: 'red' as const },
  { label: 'Our Offer', value: 'Within 24 hours', color: 'green' as const },
  { label: 'Your Repair Cost', value: '$0', color: 'green' as const },
];

// Other cities in same county
const countyPills = county.cities
  .filter((c) => c.slug !== city.slug)
  .map((c) => ({ label: c.name, href: cityUrl(stateSlug, county.slug, c.slug) }));

// Related links
const relatedLinks = [
  { label: 'Tax-Delinquent Properties', href: '/tax-delinquent/' },
  { label: 'Probate Guide', href: '/probate/' },
  { label: 'Pre-Foreclosure Help', href: '/situations/pre-foreclosure/' },
  { label: 'Inherited Property', href: '/situations/inherited-property/' },
  { label: 'Behind on Payments', href: '/situations/behind-on-payments/' },
  { label: 'Foundation Issues', href: '/situations/foundation-issues/' },
];

const countyContacts: Record<string, { label: string; value: string; href?: string }[]> = {
  wyandotte: [
    { label: 'Office', value: 'Wyandotte County Appraiser' },
    { label: 'Phone', value: '(913) 573-2810', href: 'tel:9135732810' },
    { label: 'Address', value: '710 N 7th St, Kansas City, KS 66101' },
    { label: 'Website', value: 'wycokck.org', href: 'https://www.wycokck.org' },
  ],
  johnson: [
    { label: 'Office', value: 'Johnson County Appraiser' },
    { label: 'Phone', value: '(913) 715-0725', href: 'tel:9137150725' },
    { label: 'Address', value: '100 N Kansas Ave, Olathe, KS 66061' },
    { label: 'Website', value: 'jocogov.org', href: 'https://www.jocogov.org' },
  ],
};

const contactItems = countyContacts[county.slug] || [];

const breadcrumbs = [
  { label: stateName, href: `/${stateSlug}/` },
  { label: `${county.name}`, href: `/${stateSlug}/${county.slug}/` },
  { label: city.name },
];

const title = `Sell Your House for Cash in ${city.name}, ${stateAbbr}`;
const description = `We buy houses in ${city.name}, ${stateName}. ${city.neighborhoods.length} neighborhoods served. No repairs, no agents, no fees. Get a fair cash offer within 24 hours.`;
const shortAnswer = `Yes, we buy houses in any condition in ${city.name}, ${stateName}. Whether your home needs major repairs, has code violations, or you simply need to sell quickly — we make a fair cash offer based on the local ${city.name} market and close on your schedule.`;

// Collect common distress factors across neighborhoods
const allDistressFactors = [...new Set(city.neighborhoods.flatMap((n) => n.distressFactors))].slice(0, 8);

// Common situations
const situations = [
  { title: 'Pre-Foreclosure', href: '/situations/pre-foreclosure/', desc: 'Sell before the bank forecloses and protect your credit.' },
  { title: 'Inherited Property', href: '/situations/inherited-property/', desc: 'Skip the hassle of repairing and listing an inherited home.' },
  { title: 'Divorce', href: '/situations/divorce/', desc: 'Sell the shared home quickly and split proceeds fairly.' },
  { title: 'Behind on Payments', href: '/situations/behind-on-payments/', desc: 'Stop the spiral of late fees and mounting debt.' },
  { title: 'Vacant Property', href: '/situations/vacant-property/', desc: 'Stop paying to maintain a house nobody lives in.' },
  { title: 'Foundation Issues', href: '/situations/foundation-issues/', desc: 'Sell as-is without spending $10K-$80K on foundation work.' },
];
---

<LocationHubTemplate
  title={title}
  description={description}
  shortAnswer={shortAnswer}
  breadcrumbs={breadcrumbs}
  children={children}
  facts={facts}
  locationName={city.name}
  contactItems={contactItems}
  pillsTitle="Nearby Cities"
  countyPills={countyPills}
  relatedLinks={relatedLinks}
  canonical={`${brand.domain}/${stateSlug}/${county.slug}/${city.slug}/`}
>
  <!-- DEEP SLOT CONTENT -->

  <section class="content-section">
    <h2>Common Property Issues We See in {city.name}</h2>
    <div class="section-body">
      <p>
        Every city has its own set of housing challenges, and {city.name} is no exception.
        These are the problems that scare off traditional buyers and make listing on the MLS
        an uphill battle. We buy homes with every single one of these issues — and more.
      </p>
    </div>
    {allDistressFactors.length > 0 && (
      <ul class="issue-list">
        {allDistressFactors.map((factor) => (
          <li class="issue-item">
            <span class="issue-icon">&#10003;</span>
            <span>{factor}</span>
          </li>
        ))}
      </ul>
    )}
    <CalloutBox
      type="info"
      title="EVERY CONDITION WELCOME"
      text={`We've bought hundreds of homes in the Kansas City metro. Foundation cracks, fire damage, mold, hoarder conditions, code violations — none of it stops us from making a fair offer. The condition of your ${city.name} home is our problem to solve, not yours.`}
    />
  </section>

  <section class="content-section">
    <h2>Who Sells Their {city.name} Home to Us?</h2>
    <div class="section-body">
      <p>
        We work with {city.name} homeowners in every situation you can imagine.
        People facing foreclosure who need to close before the bank sale date.
        Families who inherited a house and don't want to deal with repairs, cleanouts,
        or months of showings. Landlords tired of problem tenants destroying their investment.
        Couples going through divorce who need to sell quickly and split the proceeds.
      </p>
      <p>
        The common thread? Traditional listing doesn't work for their situation.
        When you need to sell fast, can't afford repairs, or don't want the stress and
        uncertainty of the MLS, a cash offer from an experienced {city.name} buyer
        is the practical path forward.
      </p>
    </div>
  </section>

  <!-- Attractions -->
  {(() => {
    const cityAttractions = [...new Set(city.neighborhoods.flatMap((n) => n.landmarks))].slice(0, 4);
    return cityAttractions.length > 0 ? (
      <section class="content-section">
        <h2>What Makes {city.name} a Great Place to Live?</h2>
        <div class="section-body">
          <p>
            {city.name} offers a mix of local culture, outdoor spaces, and community landmarks
            that make it more than just a place to own property. These are some of the spots
            that residents value most.
          </p>
        </div>
        <div class="attractions-grid">
          {cityAttractions.map((a) => (
            <div class="attraction-card">
              <svg class="attraction-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>{a}</span>
            </div>
          ))}
        </div>
      </section>
    ) : null;
  })()}

  <section class="content-section">
    <h2>Common Situations in {city.name}</h2>
    <div class="sit-grid">
      {situations.map((sit) => (
        <a href={sit.href} class="sit-card">
          <h3>{sit.title}</h3>
          <p>{sit.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <CalloutBox
    type="fact"
    title={`${county.name.toUpperCase()} TAX INFO`}
    text={county.taxLienInfo}
  />

  <section class="content-section">
    <h2>What Should {city.name} Homeowners Know About Property Taxes?</h2>
    <div class="section-body">
      <p>
        If you've fallen behind on property taxes in {city.name}, the clock is already running.
        {county.taxLienInfo} Back taxes, interest, and penalties compound fast. A home worth
        {city.medianHomeValue} can rack up $10,000 or more in tax debt over just a few years.
      </p>
      <p>
        You don't need to pay off back taxes before selling to us. At closing, the title company
        uses the sale proceeds to clear all tax liens, mechanic's liens, and judgment liens.
        You walk away with the remaining equity — and a clean break from the property.
      </p>
    </div>
  </section>

  <section class="content-section">
    <h2>How We Handle Inherited and Probate Properties in {city.name}</h2>
    <div class="section-body">
      <p>
        Inherited homes are one of the most common reasons {city.name} homeowners call us.
        Mom or Dad passed away, the house hasn't been maintained, and now multiple family
        members need to agree on what to do. {county.probateInfo}
      </p>
      <p>
        Whether probate is already complete, still in progress, or hasn't even been filed yet,
        we can work with your situation. Our team has experience with {county.name}
        probate and can coordinate with your attorney to close as soon as the court allows.
        We buy inherited homes in any condition — you don't need to clean out, repair, or
        even visit the property.
      </p>
    </div>
  </section>

  <section class="content-section">
    <h2>Understanding Your {city.name} Home's Value in Today's Market</h2>
    <div class="section-body">
      <p>
        The median home value in {city.name} is {city.medianHomeValue}. That number represents
        the midpoint — half the homes in {city.name} are worth more, half are worth less. But
        median value and what a buyer will actually pay are two different things. If your home
        needs foundation work, a new roof, or major mechanical updates, a retail buyer on the
        MLS will either pass on your listing entirely or demand tens of thousands in concessions
        after the inspection. The gap between what your home is "worth" and what you actually
        walk away with after commissions, repairs, closing costs, and months of holding costs
        can be staggering.
      </p>
      <p>
        In {county.name}, property values have shifted significantly in recent years. Reassessments,
        rising insurance costs, and interest rate changes have all affected what buyers are willing
        to pay and what sellers can realistically expect. For homeowners sitting on deferred
        maintenance or dealing with financial pressure, the traditional selling process often
        costs more than it returns. A cash offer based on the current {city.name} market — not
        an inflated Zestimate — gives you a realistic number you can plan around.
      </p>
      <p>
        We calculate our offers using actual comparable sales in your {city.name} neighborhood,
        not automated estimates. We factor in the property's condition, lot size, location within
        the city, and current buyer demand. Our goal is a price that works for both sides — fair
        enough that you walk away with real equity, practical enough that we can invest in the
        repairs and bring the home back to market. That transparency is why {city.name}
        homeowners trust us with their biggest asset.
      </p>
    </div>
  </section>

  <section class="content-section">
    <h2>What Does the Cash Selling Process Look Like in {city.name}?</h2>
    <div class="section-body">
      <p>
        Selling your {city.name} home to us is straightforward. You call us or fill out the
        form on this page. We ask a few questions about the property — its age, condition,
        any known issues, and your timeline. Within 24 hours, we schedule a walkthrough.
        During the visit, we take notes on the home's condition and confirm the details
        you shared. There are no inspectors, no appraisers, and no strangers walking
        through your home for open houses.
      </p>
      <p>
        After the walkthrough, we present a written cash offer. The offer includes our
        purchase price, the estimated closing date, and a breakdown of how we arrived at
        the number. If you accept, we open escrow with a local {county.name} title
        company. The title company handles the lien search, pays off any outstanding
        debts from the proceeds, and coordinates the closing. You sign the paperwork,
        receive your funds via wire transfer or cashier's check, and you're done. No
        repairs, no staging, no weeks of uncertainty.
      </p>
      <p>
        Most {city.name} sellers close within 7 to 14 days of accepting our offer.
        If you need more time — to find a new place, coordinate a move, or handle
        personal matters — we work on your schedule. The closing date is yours to choose.
        We've closed on homes in {city.name} where the seller needed to move the same
        week, and we've closed on homes where the seller needed 60 days. Either way,
        once you accept the offer, the price is locked and the deal is done.
      </p>
    </div>
  </section>

</LocationHubTemplate>

<style>
  .content-section { margin: 40px 0; }
  .content-section h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--grey-100);
  }
  .section-body { color: var(--grey-700); line-height: 1.7; }
  .section-body p { margin-bottom: 16px; }
  .section-body p:last-child { margin-bottom: 0; }

  .issue-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin: 16px 0;
  }
  .issue-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 12px 16px;
    background: var(--grey-50);
    border-radius: var(--radius);
    border: 1px solid var(--grey-100);
    font-size: 0.9rem;
    color: var(--grey-700);
  }
  .issue-icon {
    color: var(--red);
    font-weight: 700;
    flex-shrink: 0;
  }

  .sit-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .sit-card {
    display: block;
    padding: 16px 20px;
    border: 1px solid var(--grey-200);
    border-radius: var(--radius);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .sit-card:hover { border-color: var(--red); box-shadow: var(--shadow-md); text-decoration: none; }
  .sit-card h3 { font-size: 1rem; font-weight: 700; color: var(--grey-900); margin-bottom: 4px; }
  .sit-card:hover h3 { color: var(--red); }
  .sit-card p { font-size: 0.85rem; color: var(--grey-500); margin: 0; }

  .attractions-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 16px;
  }
  .attraction-card {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    background: #F0FDF4;
    border-radius: var(--radius);
    border: 1px solid #BBF7D0;
    font-size: 0.9rem;
    color: var(--grey-700);
  }
  .attraction-icon {
    color: #16A34A;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .issue-list { grid-template-columns: 1fr; }
    .sit-grid { grid-template-columns: 1fr; }
    .attractions-grid { grid-template-columns: 1fr; }
  }
</style>
