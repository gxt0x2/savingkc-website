---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import CalloutBox from '@/components/CalloutBox.astro';
import LeadForm from '@/components/LeadForm.astro';
import { getCountiesByState, getCountyBySlug } from '@/data/counties';
import { cityUrl, countyUrl } from '@/lib/urls';
import { brand } from '@/data/brand';

export function getStaticPaths() {
  return getCountiesByState('ks').map((c) => ({
    params: { county: c.slug },
    props: { county: c },
  }));
}

const { county } = Astro.props;

const title = `Sell Your House for Cash in ${county.name} County, KS`;
const description = `We buy houses in ${county.name} County, Kansas. ${county.cities.length} cities served. Get a fair cash offer within 24 hours.`;

const countyPills = getCountiesByState('ks')
  .filter((c) => c.slug !== county.slug)
  .map((c) => ({ label: `${c.name} County`, href: countyUrl('ks', c.slug) }));

const relatedLinks = [
  { label: 'Tax-Delinquent Properties', href: '/tax-delinquent/' },
  { label: 'Probate Properties', href: '/probate/' },
  { label: 'Pre-Foreclosure', href: '/situations/pre-foreclosure/' },
  { label: 'Inherited Property', href: '/situations/inherited-property/' },
];

const facts = [
  { label: 'County Seat', value: county.seatCity },
  { label: 'Population', value: county.population },
  { label: 'Median Home Value', value: county.medianHomeValue },
  { label: 'Cities Served', value: `${county.cities.length}` },
];
---

<BaseLayout title={title} description={description} canonical={`${brand.domain}/ks/${county.slug}/`}>
  <div class="container page-grid">
    <article class="content-col">
      <Breadcrumbs items={[
        { label: 'Kansas', href: '/ks/' },
        { label: `${county.name} County` },
      ]} />

      <header class="hero">
        <h1>{title}</h1>
        <p class="hero-sub">{county.description}</p>
      </header>

      <div class="short-answer">
        <p><strong>Short answer:</strong> Yes, we buy houses in any condition across {county.name} County, Kansas. Our cash offers are based on current local market data, and we close on your schedule, as fast as 7 days.</p>
      </div>

      <div class="facts-bar">
        {facts.map((f) => (
          <div class="fact">
            <span class="fact-label">{f.label}</span>
            <span class="fact-value">{f.value}</span>
          </div>
        ))}
      </div>

      <CalloutBox type="info" text={county.taxLienInfo} />
      <CalloutBox type="fact" text={county.probateInfo} />

      <section class="content-section">
        <h2>Cities in {county.name} County</h2>
        <div class="card-grid">
          {county.cities.map((c) => (
            <a href={cityUrl('ks', county.slug, c.slug)} class="location-card">
              <h3>{c.name}</h3>
              <p class="card-meta">{c.neighborhoods.length} neighborhoods | Median: {c.medianHomeValue}</p>
              <p>{c.description.substring(0, 120)}...</p>
            </a>
          ))}
        </div>
      </section>

      <nav class="pill-nav" aria-label="Other Kansas counties">
        <span class="pill-label">Other counties:</span>
        {countyPills.map((pill) => (
          <a href={pill.href} class="pill">{pill.label}</a>
        ))}
      </nav>

      <section class="content-section">
        <h2>Related Resources</h2>
        <div class="related-links">
          {relatedLinks.map((link) => (
            <a href={link.href} class="related-link">{link.label}</a>
          ))}
        </div>
      </section>
    </article>

    <aside class="sidebar-col">
      <LeadForm />
    </aside>
  </div>
</BaseLayout>

<style>
  .page-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 48px;
    padding-top: 40px;
    padding-bottom: 60px;
  }
  .content-col { min-width: 0; }
  .sidebar-col { position: sticky; top: calc(var(--nav-height) + 24px); align-self: start; }

  .hero { margin-bottom: 24px; }
  .hero h1 { font-size: 2.2rem; color: var(--grey-900); margin-bottom: 12px; }
  .hero-sub { font-size: 1.1rem; color: var(--grey-600); line-height: 1.6; }

  .short-answer {
    background: var(--cream);
    border-left: 4px solid var(--red);
    padding: 20px 24px;
    border-radius: var(--radius);
    margin-bottom: 24px;
  }
  .short-answer p { margin: 0; line-height: 1.6; }

  .facts-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 32px;
    padding: 20px;
    background: var(--grey-50);
    border-radius: var(--radius);
  }
  .fact { text-align: center; }
  .fact-label { display: block; font-size: 0.8rem; color: var(--grey-500); margin-bottom: 4px; }
  .fact-value { display: block; font-size: 1.1rem; font-weight: 700; color: var(--grey-900); }

  .content-section { margin-bottom: 40px; }
  .content-section h2 {
    font-size: 1.5rem;
    color: var(--grey-900);
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--grey-200);
  }

  .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
  .location-card {
    display: block;
    padding: 20px;
    border: 1px solid var(--grey-200);
    border-radius: var(--radius);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .location-card:hover { border-color: var(--red); box-shadow: var(--shadow); text-decoration: none; }
  .location-card h3 { font-size: 1.1rem; color: var(--grey-900); margin-bottom: 4px; }
  .card-meta { font-size: 0.85rem; color: var(--grey-500); margin-bottom: 8px; }
  .location-card p { font-size: 0.9rem; color: var(--grey-600); line-height: 1.5; }

  .pill-nav { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 32px; align-items: center; }
  .pill-label { font-size: 0.9rem; color: var(--grey-500); font-weight: 500; }
  .pill {
    display: inline-block;
    padding: 6px 16px;
    border-radius: 999px;
    background: var(--grey-100);
    color: var(--grey-700);
    font-size: 0.9rem;
    font-weight: 500;
  }
  .pill:hover { background: var(--red); color: var(--white); text-decoration: none; }

  .related-links { display: flex; flex-wrap: wrap; gap: 12px; }
  .related-link {
    padding: 8px 20px;
    background: var(--grey-100);
    border-radius: var(--radius);
    font-weight: 500;
    color: var(--grey-700);
  }
  .related-link:hover { background: var(--red); color: var(--white); text-decoration: none; }

  @media (max-width: 900px) {
    .page-grid { grid-template-columns: 1fr; gap: 32px; }
    .sidebar-col { position: static; }
    .facts-bar { grid-template-columns: repeat(2, 1fr); }
    .hero h1 { font-size: 1.8rem; }
  }
</style>
