---
import LocationHubTemplate from '@/components/LocationHubTemplate.astro';
import CalloutBox from '@/components/CalloutBox.astro';
import { getCountiesByState, getCountyBySlug } from '@/data/counties';
import { cityUrl, countyUrl } from '@/lib/urls';
import { brand } from '@/data/brand';

export function getStaticPaths() {
  return getCountiesByState('mo').map((c) => ({
    params: { county: c.slug },
    props: { county: c },
  }));
}

const { county } = Astro.props;
const stateAbbr = 'MO';
const stateName = 'Missouri';
const stateSlug = 'mo';

// Build children (cities) for the LocationHubTemplate
const children = county.cities.map((c) => ({
  name: c.name,
  href: cityUrl(stateSlug, county.slug, c.slug),
  subtitle: `${c.neighborhoods.length} neighborhoods | Median: ${c.medianHomeValue}`,
  description: c.description,
}));

// Quick facts for sidebar
const facts = [
  { label: 'County Seat', value: county.seatCity },
  { label: 'Population', value: county.population },
  { label: 'Median Home Value', value: county.medianHomeValue, color: 'red' as const },
  { label: 'Cities Served', value: `${county.cities.length}` },
  { label: 'Our Offer', value: 'Within 24 hours', color: 'green' as const },
  { label: 'Your Repair Cost', value: '$0', color: 'green' as const },
];

// County pills (other counties in same state)
const countyPills = getCountiesByState(stateSlug)
  .filter((c) => c.slug !== county.slug)
  .map((c) => ({ label: c.name, href: countyUrl(stateSlug, c.slug) }));

// Related links
const relatedLinks = [
  { label: 'Tax-Delinquent Properties', href: '/tax-delinquent/' },
  { label: 'Probate Guide', href: '/probate/' },
  { label: 'Pre-Foreclosure', href: '/situations/pre-foreclosure/' },
  { label: 'Inherited Property', href: '/situations/inherited-property/' },
  { label: 'Behind on Payments', href: '/situations/behind-on-payments/' },
];

const breadcrumbs = [
  { label: stateName, href: `/${stateSlug}/` },
  { label: `${county.name}` },
];

const title = `Navigating ${county.name} Distressed Property: Your 2026 Guide to Probate, Tax Delinquency, and Redemption`;
const description = `Navigating Probate, Tax Delinquency, and Redemption in ${county.name}, ${stateName}. Expert guidance for distressed property owners across ${county.cities.length} cities.`;
const shortAnswer = `Whether you're navigating probate through the ${county.probateCourtName}, facing a tax lien sale, or trying to understand your redemption rights in ${county.name} — you have options. We help ${county.name} property owners resolve distressed situations with fair cash offers, no repairs, and closings as fast as 7 days.`;

const heroSubtitle = `${county.name} property owners facing probate through the ${county.probateCourtName}, tax delinquency with a ${county.taxSaleMonth} lien sale, or redemption questions under RSMo Chapter 140 — we've helped families in your exact situation. Our office is ${county.courthouse.distanceMiles} miles from the ${county.courthouse.name} at ${county.courthouse.address}. RSMo 473 governs probate; Chapter 140 governs tax sales. We know both.`;

const heroStats = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    number: '47+',
    label: 'Happy Sellers Helped',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    number: '11+',
    label: 'Years Serving KC Metro',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
    number: '15 Day',
    label: 'Average Closing',
  },
];

// Build contact items from courthouse data
const contactItems = [
  { label: 'Office', value: county.courthouse.name },
  { label: 'Phone', value: county.courthouse.phone, href: `tel:${county.courthouse.phone.replace(/[^0-9]/g, '')}` },
  { label: 'Address', value: county.courthouse.address },
  { label: 'Website', value: county.courthouse.website.replace('https://', '').replace('http://', ''), href: county.courthouse.website },
];

// Collect neighborhood distress data for the county page
const distressCards = county.cities.slice(0, 3).flatMap((c) =>
  c.neighborhoods.slice(0, 2).map((n) => ({
    neighborhood: n.name,
    city: c.name,
    factors: n.distressFactors,
    hook: n.localHook,
  }))
);

// Jump pill data for repeated navigation
const jumpPills = [
  { href: '#probate-help', label: 'Probate / Inherited', desc: 'Sell inherited property during or after probate', color: '#3B82F6' },
  { href: '#tax-delinquent-solutions', label: 'Back Taxes', desc: 'Resolve delinquent property taxes before sale', color: '#CC0000' },
  { href: '#tax-redemption-rights', label: 'Tax Redemption', desc: 'Understand your redemption rights and deadlines', color: '#D97706' },
  { href: '#county-resources', label: 'Courthouse & Resources', desc: 'County offices, contacts, and directions', color: '#6366F1' },
  { href: '#process', label: 'Get Your Offer', desc: '4-step process from call to cash in hand', color: '#16A34A' },
  { href: '#how-we-help', label: 'How Saving KC Helps', desc: `Our process for ${county.name} property owners`, color: '#9333EA' },
];
---

<LocationHubTemplate
  title={title}
  description={description}
  shortAnswer={shortAnswer}
  breadcrumbs={breadcrumbs}
  children={children}
  facts={facts}
  locationName={`${county.name}`}
  contactItems={contactItems}
  countyPills={countyPills}
  relatedLinks={relatedLinks}
  canonical={`${brand.domain}/${stateSlug}/${county.slug}/`}
  countyFaqs={county.countyFaqs}
  courthouseName={county.courthouse.name}
  courthouseAddress={county.courthouse.address}
  courthouseWebsite={county.courthouse.website}
  heroStats={heroStats}
  heroSubtitle={heroSubtitle}
  heroHighlight=""
>
  <!-- QUICK-JUMP ANCHOR MENU (FULL) -->
  <nav class="anchor-menu" aria-label="Jump to section">
    <h3 class="anchor-menu__title">Table of Contents</h3>
    <div class="anchor-pills">
      {jumpPills.map((p) => (
        <a href={p.href} class="anchor-pill" style={`--pill-accent: ${p.color}`}>
          <span class="anchor-pill__label">{p.label}</span>
          <span class="anchor-pill__desc">{p.desc}</span>
        </a>
      ))}
    </div>
  </nav>

  <!-- JUMP BAR -->
  <nav class="jump-bar">{jumpPills.map((p) => (<a href={p.href} class="jump-bar__link" style={`--jb-color: ${p.color}`}>{p.label}</a>))}</nav>

  <!-- ENTITY PROXIMITY SECTION -->
  <section class="content-section" id="entity-connection">
    <h2>Local Expertise Near the {county.name} Courthouse</h2>
    <p class="answer-block">
      Saving KC Homebuyers operates from 1712 Main St in Kansas City — {county.courthouse.distanceMiles} miles from the {county.courthouse.name} at {county.courthouse.address}. We file documents, attend hearings, and close transactions through local title companies in {county.seatCity} multiple times a week. Call <a href="tel:8164292900">(816) 429-2900</a>.
    </p>
    <div class="section-body">
      <p>
        {county.narrativeHook}
      </p>
      <p>
        This proximity ensures faster document filing for probate cases and quicker title searches for tax-delinquent properties. When a deadline is measured in days — not weeks — having boots on the ground at the {county.courthouse.name} matters. We know the recording timelines, the staff at the recorder's office, and the title companies that specialize in distressed closings in {county.seatCity}.
      </p>
    </div>
  </section>

  <!-- JUMP BAR -->
  <nav class="jump-bar">{jumpPills.map((p) => (<a href={p.href} class="jump-bar__link" style={`--jb-color: ${p.color}`}>{p.label}</a>))}</nav>

  <!-- SECTION 1: PROBATE -->
  <section class="content-section" id="probate-help">
    <h2>How Do I Sell Inherited Property in {county.name}?</h2>
    <p class="answer-block">
      Yes, you can sell inherited real estate in Missouri during probate if you have Letters Testamentary and, in some cases, court approval. In {county.name}, the {county.probateCourtName} oversees estate proceedings that typically take 6 to 18 months. During that time, you're responsible for taxes, insurance, and upkeep on a home you may not want — but you don't have to wait to sell. To bypass repairs and long listing times, contact Saving KC at <a href="tel:8164292900">(816) 429-2900</a> for a direct cash offer while the estate is still open.
    </p>
    <a href="/get-offer/" class="inline-cta">Get My Cash Offer →</a>
    <div class="section-body">
      <p>
        Losing a family member is painful enough without the burden of managing their property. When you inherit a home in {county.name}, you're suddenly responsible for coordinating with the {county.probateCourtName}, keeping up with property taxes, maintaining homeowner's insurance, and handling maintenance on a house that may be miles away — all while you're grieving.
      </p>
      <p>
        It's a lot. You didn't ask for this responsibility, and you shouldn't have to navigate it alone.
      </p>
      <p>
        Missouri probate works in two main modes. Independent administration is the most common — it allows a personal representative to manage and sell estate property with limited court oversight. You'll need Letters Testamentary, the court-issued document that authorizes you to legally act on behalf of the estate, including signing contracts and closing on a sale.
      </p>
      <CalloutBox
        variant="blue"
        title="TWO TYPES OF PROBATE IN MISSOURI"
        text={`<strong>Independent administration</strong> lets you sell the property with minimal court involvement. <strong>Supervised administration</strong> requires court approval for every transaction — adding months and cost. Ask your attorney which type applies to your ${county.name} estate before signing anything.`}
      />
      <p>
        In supervised administration, the court must approve every significant transaction, which adds time and cost. If the will specifies supervised administration, or the court orders it due to creditor disputes, your timeline gets longer. Knowing which type applies to your situation matters before you sign anything.
      </p>
      <p>
        {county.probateInfo}
      </p>
      <h3>The 2026 Missouri Electronic Wills Act</h3>
      <CalloutBox
        variant="yellow"
        title="ELECTRONIC WILLS IN MISSOURI"
        text={`Missouri now recognizes electronic wills signed after August 28, 2025. If your loved one created a will electronically — through a notarized digital platform or witnessed video signing — the ${county.probateCourtName} can accept it for probate. Not sure if an electronic will is valid? An estate attorney familiar with the ${county.probateCourtName} can tell you in one conversation. Or call us — we'll connect you with one. <a href="tel:8164292900">816-429-2900</a>.`}
      />
      <p>
        If the estate's personal property is valued at $40,000 or less, Missouri allows a simplified process called a small-estate affidavit. This bypasses formal probate entirely. You file the affidavit with the {county.probateCourtName}, wait 30 days after the date of death, and can then transfer or sell the property without full court proceedings.
      </p>
      <p>
        Full probate in {county.name} typically takes 6 to 18 months. Filing fees run $50 to $200. Attorney fees range from $2,000 to $5,000 or more depending on complexity. If the estate requires a bond, that's an additional cost. During this entire period, you're paying property taxes, homeowner's insurance, and possibly a mortgage — on a property that may be sitting vacant and deteriorating.
      </p>
      <p>
        You don't need to wait for the court to close the estate. In Missouri, inherited real estate can be sold during probate with court approval. Whether probate is complete, in progress, or hasn't been filed yet, you have options. We buy inherited properties at any stage — you don't need to clean out, repair, or even visit the property. We handle the title work, coordinate with the court, and close on your timeline.
      </p>
    </div>
    <CalloutBox
      variant="green"
      title="SELLING IS AN OPTION"
      text={`You don't have to wait for probate to close, repairs to be made, or the estate to be settled. We buy inherited properties in ${county.name} at any stage — as-is, no cleaning, no repairs. <a href="tel:8164292900">Call 816-429-2900</a> to discuss your situation.`}
    />

    <!-- Probate Timeline -->
    <h3>Missouri Probate Timeline</h3>
    <div class="process-timeline">
      <div class="process-timeline__step">
        <span class="process-timeline__number">1</span>
        <div class="process-timeline__title">Death of Property Owner</div>
        <p class="process-timeline__desc">Estate administration begins. Locate the will, death certificate, and identify heirs or beneficiaries.</p>
      </div>
      <div class="process-timeline__step">
        <span class="process-timeline__number">2</span>
        <div class="process-timeline__title">File Probate with {county.probateCourtName}</div>
        <p class="process-timeline__desc">Submit the will and petition to open probate. Filing fees: $50–$200. The court appoints a personal representative.</p>
      </div>
      <div class="process-timeline__step">
        <span class="process-timeline__number">3</span>
        <div class="process-timeline__title">Receive Letters Testamentary</div>
        <p class="process-timeline__desc">Court issues authority to act on behalf of the estate — including the legal power to sell real property.</p>
      </div>
      <div class="process-timeline__step">
        <span class="process-timeline__number">4</span>
        <div class="process-timeline__title">Sell Property (During Probate)</div>
        <p class="process-timeline__desc">You don't have to wait for the estate to close. With Letters Testamentary, you can accept a cash offer and close.</p>
      </div>
      <div class="process-timeline__step">
        <span class="process-timeline__number">5</span>
        <div class="process-timeline__title">Close Estate</div>
        <p class="process-timeline__desc">Final accounting, distribute remaining assets, and close the estate with the court. Typically 6–18 months total.</p>
      </div>
    </div>

    <CalloutBox
      type="info"
      title={`${county.name.toUpperCase()} PROBATE COURT`}
      text={`Probate cases in ${county.name} are handled by the ${county.probateCourtName}, located at ${county.courthouse.address}. Our office is ${county.courthouse.distanceMiles} miles away — we work with this court regularly and can coordinate with your attorney to close as soon as the court allows.`}
    />
  </section>

  <!-- JUMP BAR -->
  <nav class="jump-bar">{jumpPills.map((p) => (<a href={p.href} class="jump-bar__link" style={`--jb-color: ${p.color}`}>{p.label}</a>))}</nav>

  <!-- SECTION 2: TAX DELINQUENT -->
  <section class="content-section" id="tax-delinquent-solutions">
    <h2>What Happens When You Owe Back Taxes in {county.name}?</h2>
    <p class="answer-block">
      Your property faces tax lien sale if taxes remain unpaid past {county.taxDeadline}. In {county.name}, delinquent properties go to auction in {county.taxSaleMonth}. Penalties accrue at 1% per month from the first missed deadline. Once a lien is sold, you face a one-year countdown to redeem — or lose the property entirely. If you are behind on taxes, Saving KC (<a href="tel:8164292900">816-429-2900</a>) can clear your debt at closing, allowing you to walk away with your remaining equity.
    </p>
    <div class="section-body">
      <p>
        Property tax in {county.name} is due {county.taxDeadline} each year. Miss that deadline and penalties start immediately — 1% per month on the unpaid balance, compounding month after month. By {county.taxSaleMonth}, the county places delinquent properties on the auction list for tax lien certificate sales. Once your property hits that list, the clock isn't ticking anymore — it's counting down.
      </p>
      <p>
        {county.taxLienInfo}
      </p>
      <p>
        Missouri conducts tax lien sales — not tax deed sales. This distinction matters. The county sells a certificate representing your unpaid taxes to the highest bidder at public auction. You still own the property after the sale. But the lien holder now has a legal claim against it and earns interest on their investment while you face a one-year redemption countdown.
      </p>
      <CalloutBox
        variant="red"
        title="LIEN SALE VS. DEED SALE"
        text={`Missouri sells tax <strong>lien certificates</strong> — not the property itself. You still own the home after the sale. But if you don't pay off the lien within one year (full amount + 10% interest + costs), the lien holder petitions for a <strong>collector's deed</strong>. At that point, ownership transfers permanently.`}
      />
      <p>
        The math on catching up rarely works in your favor. Back taxes, 1% monthly interest, penalties, and potential legal fees compound fast. A home worth {county.medianHomeValue} can accumulate $10,000 or more in tax debt over just a few years. By the time you add attorney fees to contest the sale, you may owe more than the property is worth.
      </p>
      <p>
        Missouri reassesses property values {county.reassessmentCycle}, which means your tax bill can change even if you've made no improvements. If rising assessments have pushed your tax burden beyond what you can manage, selling eliminates that obligation entirely.
      </p>
      <p>
        You don't need to pay off back taxes before selling. At closing, the title company uses the sale proceeds to clear all tax liens, mechanic's liens, and judgment liens. You walk away with the remaining equity — and a clean break from the property. No lump sum required. No negotiating with the lien holder. No attorney fees to come up with before you can act.
      </p>
    </div>
    <h3>2026 Tax Sale Critical Dates</h3>
    <table class="data-table">
      <thead>
        <tr>
          <th>DETAIL</th>
          <th>INFORMATION</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Tax Sale Period</td>
          <td>{county.taxSaleDates}</td>
        </tr>
        <tr>
          <td>Sale Location</td>
          <td>{county.taxSaleLocation}</td>
        </tr>
        <tr>
          <td>Annual Tax Deadline</td>
          <td>{county.taxDeadline}</td>
        </tr>
        <tr>
          <td>Pre-Registration</td>
          <td>{county.taxSalePreRegDeadline}</td>
        </tr>
      </tbody>
    </table>

    <!-- Tax Delinquency Timeline -->
    <h3>{county.name} Tax Delinquency Timeline</h3>
    <div class="process-timeline">
      <div class="process-timeline__step">
        <span class="process-timeline__number">1</span>
        <div class="process-timeline__title">December 31 — Tax Due Date</div>
        <p class="process-timeline__desc">Property taxes are due by {county.taxDeadline}. Miss this date and penalties start at 1% per month.</p>
      </div>
      <div class="process-timeline__step">
        <span class="process-timeline__number">2</span>
        <div class="process-timeline__title">Penalties Begin Accruing</div>
        <p class="process-timeline__desc">1% per month interest on the unpaid balance. Compounding month after month with no cap in sight.</p>
      </div>
      <div class="process-timeline__step">
        <span class="process-timeline__number">3</span>
        <div class="process-timeline__title">{county.taxSaleMonth} — Lien Sale</div>
        <p class="process-timeline__desc">The county sells a tax lien certificate to the highest bidder at public auction. You still own the property — but the clock starts.</p>
      </div>
      <div class="process-timeline__step">
        <span class="process-timeline__number">4</span>
        <div class="process-timeline__title">One-Year Redemption Period</div>
        <p class="process-timeline__desc">You have exactly one year to pay the full lien amount + 10% interest + all costs incurred by the lien purchaser.</p>
      </div>
      <div class="process-timeline__step">
        <span class="process-timeline__number">5</span>
        <div class="process-timeline__title">Collector's Deed — Ownership Lost</div>
        <p class="process-timeline__desc">If you don't redeem, the lien holder petitions for a collector's deed. Ownership transfers permanently. No second chance.</p>
      </div>
    </div>

    <CalloutBox
      variant="gray"
      text={`Every month you wait, penalties grow. Every month the lien holder waits, their claim strengthens. Selling your ${county.name} property now clears all tax debt at closing and puts remaining equity in your hands. <a href="tel:8164292900">Call Ernest: 816-429-2900</a>.`}
    />
    <CalloutBox
      type="fact"
      title={`${county.name.toUpperCase()} TAX DEADLINE`}
      text={`Your ${county.name} property tax is due ${county.taxDeadline}. Delinquent properties go to lien sale in ${county.taxSaleMonth}. If you're behind, selling is faster than catching up — we can close in as few as 7 days.`}
    />
  </section>

  <!-- JUMP BAR -->
  <nav class="jump-bar">{jumpPills.map((p) => (<a href={p.href} class="jump-bar__link" style={`--jb-color: ${p.color}`}>{p.label}</a>))}</nav>

  <!-- SECTION 3: TAX REDEMPTION -->
  <section class="content-section" id="tax-redemption-rights">
    <h2>How Do I Redeem Tax-Delinquent Property in {county.name}?</h2>
    <p class="answer-block">
      You have exactly one year from the date of the tax lien sale to redeem your property in {county.name}. You must pay the full lien amount plus 10% interest plus all costs incurred by the lien purchaser. Miss that window and the lien holder petitions for a collector's deed — permanently transferring ownership away from you. To avoid losing ownership permanently, contact Saving KC at <a href="tel:8164292900">(816) 429-2900</a> to discuss a cash buyout that protects your equity.
    </p>
    <div class="section-body">
      <p>
        After a tax lien is sold in {county.name}, you have exactly one year to redeem your property. During that year, you must pay the full lien amount, plus 10% interest, plus all costs the lien purchaser incurred — including recording fees, title search costs, and legal fees. If you don't redeem within that window, the lien holder petitions the court for a collector's deed. Once that deed is issued, ownership of your property transfers permanently. There is no second chance, no appeal process, no grace period after the deadline.
      </p>
    </div>

    <h3>The Redemption Math</h3>
    <CalloutBox
      variant="yellow"
      title="WHAT YOU OWE TO REDEEM"
      text={`To redeem your ${county.name} property after a tax lien sale, you must pay <strong>all three</strong> of the following before the one-year deadline expires:<br/><br/><strong>1. The full lien amount</strong> — every dollar of delinquent taxes the purchaser paid at auction.<br/><strong>2. 10% annual interest</strong> — paid directly to the lien purchaser.<br/><strong>3. All costs incurred by the purchaser</strong> — title searches, recording fees, legal fees, and court costs.<br/><br/>The total adds up fast. On a ${county.medianHomeValue} home with 2–3 years of back taxes, you could owe $10,000+ just to redeem. If you can't cover that lump sum, selling to Saving KC clears the debt at closing and preserves your remaining equity. <a href="tel:8164292900">Call (816) 429-2900</a>.`}
    />

    <div class="section-body">
      <p>
        Here's the complication most homeowners miss: if there's a pending probate on the property, the redemption timeline runs concurrently with court proceedings. The estate may not have the liquidity to redeem. The heir may not have legal authority to act yet. Neither party can move fast enough. In these situations, selling the property before the redemption window closes is often the only viable path to preserving your equity. Waiting for probate to sort itself out while the redemption clock runs down is one of the most common and costly mistakes we see.
      </p>
    </div>
    <CalloutBox
      variant="red"
      title="CRITICAL DEADLINE"
      text={`If your ${county.name} property has already been through a tax lien sale, your redemption window is closing. Once the lien holder petitions for a collector's deed, ownership transfers permanently. There is no second chance. Act now — <a href="tel:8164292900">call 816-429-2900</a>.`}
    />
    <div class="section-body">
      <p>
        If your {county.name} property is approaching a tax sale or you're within the redemption period, every day matters. We can close in as few as 7 days — well before most redemption deadlines expire. You don't need to negotiate with the lien holder, hire an attorney, or come up with a lump sum. We handle everything.
      </p>
      <p>
        Missouri's legislative landscape continues to evolve. Recent bills including SB 1076 and SB 1495 have addressed interest rate caps on tax lien certificates and protections for primary residence owners facing tax sales. If your {county.name} home is your primary residence, you may have additional rights during the redemption period that limit what a lien holder can charge. We stay current on Missouri tax law changes and can help you understand how current legislation applies to your specific situation.
      </p>
    </div>
  </section>

  <!-- JUMP BAR -->
  <nav class="jump-bar">{jumpPills.map((p) => (<a href={p.href} class="jump-bar__link" style={`--jb-color: ${p.color}`}>{p.label}</a>))}</nav>

  <!-- SECTION 4A: COURTHOUSE & COUNTY OFFICES -->
  <section class="content-section" id="county-resources">
    <h2>{county.name} Courthouse & County Offices</h2>
    <p class="answer-block">
      The {county.courthouse.name} is {county.courthouse.distanceMiles} miles from our office at 1712 Main St in Kansas City. We work with this courthouse regularly — filing documents, coordinating with attorneys, and closing transactions through local title companies in {county.seatCity}.
    </p>
    <div class="section-body">
      <p>
        {county.courthouseLandmarks}
      </p>
    </div>

    <div class="resource-links">
      <div class="resource-grid">
        <div class="resource-card resource-card--featured">
          <div class="resource-card__header">
