---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import '../styles/global.css';

const faqItems = [
  {
    question: "Do you buy houses in Liberty, MO?",
    answer: "Yes! We buy houses throughout Liberty including ZIP codes 64068 and 64069. We serve all neighborhoods from Liberty Hills to Shoal Creek Valley."
  },
  {
    question: "How fast can you close on my Liberty home?",
    answer: "We can close in as few as 14 days. You pick the closing date — whether it's two weeks or two months."
  },
  {
    question: "Do I need to make repairs before selling?",
    answer: "No. We buy homes in any condition — foundation issues, storm damage, outdated interiors, you name it. Clay County's heavy clay soil causes a lot of foundation problems and we're used to it."
  },
  {
    question: "How much are property taxes in Liberty?",
    answer: "Typical property taxes in Liberty range from $3,200–$4,500 annually on a $295K home, depending on your school district and subdivision."
  },
  {
    question: "What if I inherited a house in Liberty?",
    answer: "We buy inherited properties regularly. Whether you're going through probate or already have clear title, we can work with you and close quickly."
  },
  {
    question: "Are there any fees or commissions?",
    answer: "None. Zero agent commissions, zero closing costs, zero hidden fees. The offer you accept is what you receive at closing."
  },
];

const situations = [
  { title: "Foreclosure", desc: "Stop foreclosure and protect your credit." },
  { title: "Inherited Property", desc: "Skip the probate delays and sell fast." },
  { title: "Divorce", desc: "Sell the shared home and split proceeds." },
  { title: "Back Taxes", desc: "We pay all delinquent taxes at closing." },
  { title: "Relocation", desc: "Moving? Close on your timeline." },
  { title: "Major Repairs", desc: "Foundation, roof, mold — we buy as-is." },
  { title: "Hoarding", desc: "No judgment. We handle cleanout." },
  { title: "Code Violations", desc: "Open violations won't stop us." },
  { title: "Squatters", desc: "Occupant issues? We handle it." },
  { title: "Fire Damage", desc: "Smoke, water, structural — we buy." },
  { title: "Foundation Issues", desc: "Clay soil settling? No problem." },
];

const neighborhoods = [
  "Liberty Hills",
  "Ridgeview",
  "Shoal Creek Valley",
  "Lightburne",
  "Liberty Historic District",
  "The Trails",
];
---

<BaseLayout
  title="Sell My House Fast Liberty MO | Cash Offer in 24 Hours | Saving KC"
  description="Sell your Liberty MO house fast for cash. No repairs, no fees, close in 14 days. Serving ZIP codes 64068 & 64069. Call 816-429-2900."
>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "/" },
      { "@type": "ListItem", "position": 2, "name": "Sell My House Fast Liberty" },
    ],
  })} />

  <!-- Hero -->
  <section class="city-hero">
    <div class="container city-hero-inner">
      <div class="city-hero-content">
        <div class="hero-badge">
          <span class="stars">★★★★★</span> 5-Star Google Rating
        </div>
        <h1>Sell Your Liberty Home Fast — <span class="highlight">Cash Offer in 24 Hours</span></h1>
        <p class="hero-sub">No repairs. No agent fees. No hassle. Close in as few as <strong>14 days</strong>.</p>
        <p class="hero-sub" style="font-size:0.95rem">Serving Liberty, MO — ZIP codes 64068 & 64069 — Clay County</p>
        <div class="hero-stats">
          <div class="stat"><strong>100+</strong><span>Homes Purchased</span></div>
          <div class="stat"><strong>11 yrs</strong><span>In Kansas City</span></div>
          <div class="stat"><strong>14 days</strong><span>Avg. Close Time</span></div>
        </div>
        <div class="hero-ctas">
          <a href="tel:8164292900" class="btn btn-secondary btn-lg">Call 816-429-2900</a>
          <a href="#offer-form" class="btn btn-primary btn-lg">Get My Cash Offer</a>
        </div>
      </div>
      <div class="city-hero-form">
        <LeadForm source="liberty-hero" />
      </div>
    </div>
  </section>

  <!-- Process -->
  <ProcessSteps />

  <!-- About Liberty -->
  <section class="section" style="background:var(--grey-50)">
    <div class="container">
      <h2 class="section-title">We Know Liberty, MO</h2>
      <p style="margin-bottom:20px">Liberty is one of Clay County's most desirable cities — home to William Jewell College, the Liberty Jail historic site, and the charming Liberty Square. With median home values around $295,000, it's a market with real equity potential.</p>
      <p style="margin-bottom:20px">But we also know Liberty's challenges: <strong>Clay County's heavy clay soil</strong> causes foundation settling throughout the area. Freeze-thaw cycles crack foundations, shift walls, and create expensive repair bills. Add in older homes near the historic district, and many homeowners find themselves with a house they can't afford to fix — and can't sell traditionally.</p>
      <p><strong>That's where we come in.</strong> We buy Liberty homes in any condition — foundation cracks, outdated kitchens, storm damage, inherited properties, back taxes, you name it.</p>

      <div class="neighborhoods" style="margin-top:32px">
        <h3 style="margin-bottom:16px">Liberty Neighborhoods We Serve</h3>
        <div class="neighborhood-pills">
          {neighborhoods.map((n) => (
            <span class="county-pill">{n}</span>
          ))}
          <span class="county-pill">ZIP 64068</span>
          <span class="county-pill">ZIP 64069</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Situations -->
  <section class="section">
    <div class="container">
      <h2 class="section-title" style="text-align:center">We Buy Liberty Homes In Any Situation</h2>
      <p class="section-subtitle" style="text-align:center">No matter what you're facing, we can help.</p>
      <div class="situations-grid">
        {situations.map((s) => (
          <div class="situation-card card">
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison -->
  <section class="section" style="background:var(--grey-50)">
    <div class="container">
      <h2 class="section-title" style="text-align:center">Cash Sale vs. Traditional Listing in Liberty</h2>
      <ComparisonTable />
    </div>
  </section>

  <!-- Testimonials -->
  <Testimonials />

  <!-- FAQ -->
  <FAQ items={faqItems} />

  <!-- Bottom CTA -->
  <section class="section" style="background:var(--red);color:var(--white);text-align:center">
    <div class="container">
      <h2 style="font-size:2rem;font-weight:800;margin-bottom:12px">Ready to Sell Your Liberty Home?</h2>
      <p style="font-size:1.1rem;margin-bottom:24px;opacity:0.9">Get your free, no-obligation cash offer today.</p>
      <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap">
        <a href="tel:8164292900" class="btn btn-lg" style="background:var(--white);color:var(--red)">Call 816-429-2900</a>
        <a href="#offer-form" class="btn btn-lg" style="background:rgba(255,255,255,0.15);color:var(--white);border:2px solid var(--white)">Get My Cash Offer</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .city-hero {
    background: linear-gradient(135deg, var(--grey-900) 0%, var(--grey-800) 100%);
    color: var(--white);
    padding: 80px 0;
  }
  .city-hero-inner {
    display: grid;
    grid-template-columns: 1fr 440px;
    gap: 60px;
    align-items: center;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.1);
    padding: 6px 14px;
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    margin-bottom: 20px;
  }
  .city-hero h1 {
    font-size: 2.5rem;
    font-weight: 900;
    line-height: 1.15;
    margin-bottom: 16px;
  }
  .highlight {
    color: var(--green);
  }
  .hero-sub {
    font-size: 1.15rem;
    color: var(--grey-300);
    margin-bottom: 16px;
  }
  .hero-stats {
    display: flex;
    gap: 32px;
    margin: 24px 0;
  }
  .stat strong {
    display: block;
    font-size: 1.5rem;
    color: var(--white);
  }
  .stat span {
    font-size: 0.85rem;
    color: var(--grey-400);
  }
  .hero-ctas {
    display: flex;
    gap: 16px;
  }
  .city-hero-form :global(.lead-form) {
    background: var(--white);
    color: var(--grey-800);
  }

  .neighborhood-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .situations-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .situation-card {
    text-align: center;
    padding: 20px 16px;
  }
  .situation-card h3 {
    font-size: 1rem;
    margin-bottom: 6px;
  }
  .situation-card p {
    font-size: 0.85rem;
    color: var(--grey-500);
  }

  @media (max-width: 1000px) {
    .city-hero-inner { grid-template-columns: 1fr; }
    .city-hero h1 { font-size: 2rem; }
    .city-hero-form { max-width: 440px; }
    .situations-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 640px) {
    .city-hero { padding: 40px 0; }
    .city-hero h1 { font-size: 1.7rem; }
    .hero-stats { gap: 20px; }
    .hero-ctas { flex-direction: column; }
    .situations-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
